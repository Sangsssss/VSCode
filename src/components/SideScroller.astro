    transition: color 0.2s;
  }
  .modal-close:hover { color: #ff5f57; }

  /* 모달 본문 */
  .modal-body {
    display: grid;
    grid-template-columns: 360px 1px 1fr;
    min-height: 580px;
  }

  /* 왼쪽 패널 */
  .modal-left {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    background: rgba(0,255,0,0.02);
    text-align: center;
  }
  .modal-icon {
    width: 160px; height: 160px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--border);
    background: #0a0a0a;
    margin-bottom: 0.8rem;
  }
  .modal-project-name {
    font-family: var(--font-pixel);
    font-size: 1.2rem;
    color: var(--neon);
    text-shadow: 0 0 10px var(--neon);
    letter-spacing: 0.08em;
    line-height: 1.6;
  }
  .modal-genre {
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.12em;
  }
  .modal-year-badge {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: #ffaa00;
    border: 1px solid #ffaa00;
    padding: 0.35rem 1rem;
    box-shadow: 0 0 8px rgba(255,170,0,0.4);
  }
  .modal-stack { width: 100%; text-align: left; margin-top: 0.5rem; }
  .modal-stack-label {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.8rem;
  }
  .modal-stack-chips {
    display: flex; flex-wrap: wrap; gap: 0.4rem;
  }
  .stack-chip {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    padding: 0.4rem 0.9rem;
    background: rgba(0,255,0,0.07);
    border: 1px solid var(--border);
    color: var(--neon);
  }

  /* 구분선 */
  .modal-divider { background: var(--border); }

  /* 오른쪽 패널 */
  .modal-right {
    padding: 2.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .modal-section { display: flex; flex-direction: column; gap: 0.6rem; }
  .modal-section-label {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }
  .modal-overview {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--text);
    line-height: 2;
  }
  .modal-achievements {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .modal-achievements li {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    color: var(--text-muted);
    padding-left: 1.6rem;
    position: relative;
    line-height: 1.8;
  }
  .modal-achievements li::before {
    content: '▶';
    position: absolute;
    left: 0;
    color: var(--neon);
    font-size: 0.6rem;
    top: 0.15rem;
  }
  .modal-status { display: flex; align-items: center; gap: 0.6rem; }
  .status-dot {
    width: 8px; height: 8px;
    background: var(--neon);
    box-shadow: 0 0 6px var(--neon);
    animation: blink-dot 1.2s ease-in-out infinite;
  }
  @keyframes blink-dot { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .status-text {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--neon);
    letter-spacing: 0.15em;
  }
  .modal-actions { display: flex; gap: 1rem; margin-top: auto; flex-wrap: wrap; }
  .modal-btn-primary {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    padding: 1rem 2.4rem;
    background: var(--neon);
    color: #0a0a0a;
    text-decoration: none;
    clip-path: polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);
    transition: box-shadow 0.2s;
  }
  .modal-btn-primary:hover { box-shadow: 0 0 16px var(--neon-glow); }
  .modal-btn-ghost {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    padding: 1rem 2.4rem;
    background: transparent;
    color: var(--text-muted);
    border: 1px solid rgba(255,255,255,0.15);
    cursor: none;
    transition: color 0.2s, border-color 0.2s;
  }
  .modal-btn-ghost:hover { color: var(--text); border-color: var(--text-muted); }

  /* 스캔라인 */
  .modal-scanline {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px, transparent 3px,
      rgba(0,0,0,0.06) 3px, rgba(0,0,0,0.06) 4px
    );
    z-index: 1;
  }

</style>

<!-- ── GSAP ScrollTrigger 횡스크롤 엔진 ────────────────────── -->
<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  gsap.registerPlugin(ScrollTrigger);

  const driver     = document.getElementById('scroll-driver');
  const layerSky   = document.getElementById('layer-sky');
  const layerMid   = document.getElementById('layer-mid');
  const layerGnd   = document.getElementById('layer-ground');
  const sceneCards = document.getElementById('scene-cards');
  const sprite     = document.getElementById('player-sprite');
  const speedLines = document.getElementById('speed-lines');
  const hudProg    = document.getElementById('hud-progress');

  const TRAVEL = () => window.innerWidth * 4;

  // ── 프로젝트 데이터 ──────────────────────────────────
  const PROJECTS = [
    {
      name: 'VOID RUNNER',
      genre: 'Platformer · Unity',
      year: '2024',
      icon_color: '#ffaa00',
      stack: ['Unity', 'C#', 'HLSL', 'Cinemachine', 'DOTween'],
      overview: '무한 생성 절차적 맵과 물리 기반 이동 시스템을 갖춘 2.5D 플랫포머. 플레이어가 매 런마다 다른 경험을 할 수 있도록 설계되었습니다.',
      achievements: [
        '절차적 맵 생성 알고리즘으로 재플레이성 300% 향상',
        '커스텀 캐릭터 컨트롤러로 응답성 극대화 (입력 지연 < 2ms)',
        'Steam Early Access 출시, 첫 주 2,400+ 다운로드',
        '커스텀 셰이더로 독특한 네온 비주얼 스타일 구현',
      ],
      status: 'SHIPPED',
      link: '#'
    },
    {
      name: 'NEON SIEGE',
      genre: 'Tower Defense · UE5',
      year: '2023',
      icon_color: '#00ffff',
      stack: ['Unreal Engine 5', 'C++', 'Blueprint', 'Niagara', 'Nanite'],
      overview: 'Unreal Engine 5의 Nanite·Lumen을 활용한 사이버펑크 타워 디펜스. 200개 이상의 동시 유닛을 처리하는 고성능 AI 시스템이 핵심입니다.',
      achievements: [
        'Niagara VFX 파티클 시스템으로 몰입형 전투 이펙트 구현',
        'ECS 패턴 적용으로 200+ 유닛 동시 처리 최적화',
        '게임잼 48시간 내 프로토타입 완성, 우승작 선정',
        'Lumen 글로벌 일루미네이션 실시간 적용',
      ],
      status: 'SHIPPED',
      link: '#'
    },
    {
      name: 'ECHO PROTOCOL',
      genre: 'Puzzle · Godot',
      year: '2023',
      icon_color: '#aa00ff',
      stack: ['Godot 4', 'GDScript', 'Shader (GLSL)', 'Wwise'],
      overview: '시간 되감기 메커닉을 기반으로 한 1인칭 퍼즐 게임. 플레이어의 과거 행동이 현재 퍼즐의 열쇠가 되는 독창적 구조를 갖추고 있습니다.',
      achievements: [
        '시간 역행 시스템 자체 구현 (상태 스냅샷 + 보간)',
        'Wwise 연동으로 퍼즐 진행에 반응하는 동적 사운드스케이프',
        'itch.io 퍼즐 카테고리 주간 Top 10 달성',
        '색약 접근성 모드 완비로 포용적 디자인 실현',
      ],
      status: 'SHIPPED',
      link: '#'
    },
    {
      name: 'PIXEL CRUSADE',
      genre: 'RPG · Unity',
      year: '2022',
      icon_color: '#00ff00',
      stack: ['Unity', 'C#', 'Yarn Spinner', 'Aseprite', 'FMOD'],
      overview: '16비트 감성의 픽셀아트 턴제 RPG. 분기형 내러티브와 전략적 전투 시스템이 결합된 40시간 분량의 스토리를 담고 있습니다.',
      achievements: [
        'Yarn Spinner 기반 분기 대화 시스템 2,000+ 노드 구현',
        'FMOD 적응형 음악으로 전투 강도에 따른 BGM 자동 전환',
        'Kickstarter 캠페인 목표액 180% 달성',
        '턴제 전투 AI에 A* + 우선순위 큐 적용으로 전략성 강화',
      ],
      status: 'SHIPPED',
      link: '#'
    },
  ];

  // ── 모달 로직 ────────────────────────────────────────
  const overlay   = document.getElementById('modal-overlay');
  const modalWin  = document.getElementById('modal-window');
  const closeBtn  = document.getElementById('modal-close');
  const closeBtnG = document.getElementById('modal-close-btn');

  function openModal(idx) {
    const p = PROJECTS[idx];
    document.getElementById('modal-title-text').textContent  = p.name + '.EXE';
    document.getElementById('modal-project-name').textContent = p.name;
    document.getElementById('modal-genre').textContent        = p.genre;
    document.getElementById('modal-year-badge').textContent   = p.year;
    document.getElementById('modal-overview').textContent     = p.overview;
    document.getElementById('modal-status-text').textContent  = p.status;
    document.getElementById('modal-link').href                = p.link;

    // 아이콘 색 교체
    const icon = document.getElementById('modal-icon');
    icon.style.borderColor = p.icon_color;
    icon.querySelector('svg rect:first-child').setAttribute('stroke', p.icon_color);

    // 스택 칩
    const chipsEl = document.getElementById('modal-stack-chips');
    chipsEl.innerHTML = p.stack.map(s =>
      `<span class="stack-chip">${s}</span>`
    ).join('');

    // 업적 리스트
    const achEl = document.getElementById('modal-achievements');
    achEl.innerHTML = p.achievements.map(a =>
      `<li>${a}</li>`
    ).join('');

    console.log('[Modal] opening:', p.name, overlay);
    overlay.classList.add('open');
    // body overflow hidden 제거 — 스크롤 씬에서 충돌 방지
    // document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.remove('open');
  }

  closeBtn.addEventListener('click', closeModal);
  closeBtnG.addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ── 패럴랙스 ScrollTrigger ───────────────────────────
  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: driver,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 1,
      onUpdate: (self) => {
        const p = self.progress;

        // HUD 진행바
        const pct    = Math.round(p * 100);
        const filled = Math.round(p * 10);
        const bar    = '▓'.repeat(filled) + '░'.repeat(10 - filled);
        hudProg.textContent = `${bar} ${pct}%`;

        // HUD만 onUpdate에서 처리 (walking은 ticker로 분리)

        // 보물상자 근접 감지 + 전역 툴팁 위치 제어
        const chests = document.querySelectorAll('.chest-wrap');
        const tipWrap = document.getElementById('chest-tip-wrap');
        const tipLabel = document.getElementById('chest-tip-label');
        const tipE     = document.getElementById('chest-tip-e');
        const CHEST_NAMES = ['VOID RUNNER', 'NEON SIEGE', 'ECHO PROTOCOL', 'PIXEL CRUSADE'];

        let anyNear = false;
        chests.forEach(chest => {
          const chestScreenX = parseFloat(chest.style.left || 0) - TRAVEL() * p;
          const playerX = window.innerWidth * 0.5;
          const dist = Math.abs(chestScreenX - playerX);
          const isNear = dist < 120;
          chest.classList.toggle('near', isNear);

          if (isNear) {
            anyNear = true;
            const idx = parseInt(chest.dataset.chest);
            // 상자 화면 중심 X
            const cx = chestScreenX + 44;
            // 바닥 라인 Y (scroller-sticky top=0, height=100vh, ground=22%)
            const groundY = window.innerHeight * 0.78;
            // 상자 높이 76px → 상자 상단 Y
            const chestTop = groundY - 76;
            tipLabel.textContent = CHEST_NAMES[idx];
            // 툴팁을 상자 위 중앙에 배치
            tipWrap.style.display   = 'flex';
            tipWrap.style.flexDirection = 'column';
            tipWrap.style.alignItems = 'center';
            tipWrap.style.left      = cx + 'px';
            tipWrap.style.top       = (chestTop - 90) + 'px';
            tipWrap.style.transform = 'translateX(-50%)';
          }
        });

        if (!anyNear) {
          tipWrap.style.display = 'none';
        }
      },
    }
  });

  tl.to(layerSky,   { x: () => -TRAVEL() * 0.18, ease: 'none' }, 0)
    .to(layerMid,   { x: () => -TRAVEL() * 0.50, ease: 'none' }, 0)
    .to(layerGnd,   { x: () => -TRAVEL() * 1.00, ease: 'none' }, 0)
    .to(sceneCards, { x: () => -TRAVEL() * 1.00, ease: 'none' }, 0);

  // ── 워킹 애니메이션: 측면뷰 — x/y 좌표 직접 조작 ─────────────
  const playerWrap = document.getElementById('player-wrap');

  // 측면뷰 요소들
  const legF  = document.getElementById('leg-f');
  const legB  = document.getElementById('leg-b');
  const footF = document.getElementById('foot-f');
  const footB = document.getElementById('foot-b');
  const armF  = document.getElementById('arm-f');
  const armB  = document.getElementById('arm-b');

  // idle 기준값 (새 SVG viewBox 28x40 기준)
  const BASE = {
    legF:  { x:11, y:22 }, legB:  { x:9,  y:22 },
    footF: { x:11, y:30 }, footB: { x:7,  y:30 },
    armF:  { x:18, y:12 }, armB:  { x:6,  y:12 },
  };

  let walkFrame   = 0;
  let isWalking   = false;
  let lastScrollY = window.scrollY;
  let stopTimer   = null;

  function setIdle() {
    legF.setAttribute('x',  BASE.legF.x);  legF.setAttribute('y',  BASE.legF.y);
    legB.setAttribute('x',  BASE.legB.x);  legB.setAttribute('y',  BASE.legB.y);
    footF.setAttribute('x', BASE.footF.x); footF.setAttribute('y', BASE.footF.y);
    footB.setAttribute('x', BASE.footB.x); footB.setAttribute('y', BASE.footB.y);
    armF.setAttribute('x',  BASE.armF.x);  armF.setAttribute('y',  BASE.armF.y);
    armB.setAttribute('x',  BASE.armB.x);  armB.setAttribute('y',  BASE.armB.y);
  }

  function applyWalkFrame(t) {
    const s = Math.sin(t * Math.PI * 2); // -1 ~ 1

    // 앞다리: 앞으로 나갈 때 x+, 발 들어올림 y-
    const lfX = Math.round(BASE.legF.x + s * 4);
    const lfY = Math.round(BASE.legF.y - Math.max(0, s) * 6);
    legF.setAttribute('x', lfX);
    legF.setAttribute('y', lfY);
    footF.setAttribute('x', lfX);
    footF.setAttribute('y', Math.round(BASE.footF.y - Math.max(0, s) * 5));

    // 뒷다리: 반대 위상
    const lbX = Math.round(BASE.legB.x - s * 4);
    const lbY = Math.round(BASE.legB.y - Math.max(0, -s) * 6);
    legB.setAttribute('x', lbX);
    legB.setAttribute('y', lbY);
    footB.setAttribute('x', lbX - 1);
    footB.setAttribute('y', Math.round(BASE.footB.y - Math.max(0, -s) * 5));

    // 앞팔: 다리 반대로 (뒤로 가면 팔은 앞으로)
    armF.setAttribute('y', Math.round(BASE.armF.y + s * 3));
    // 뒷팔: 앞팔 반대
    armB.setAttribute('y', Math.round(BASE.armB.y - s * 3));
  }

  // 매 프레임
  gsap.ticker.add(() => {
    const currentY = window.scrollY;
    const delta    = Math.abs(currentY - lastScrollY);
    lastScrollY    = currentY;

    if (delta > 0.3) {
      isWalking = true;
      speedLines.classList.add('active');
      clearTimeout(stopTimer);
      stopTimer = setTimeout(() => {
        isWalking = false;
        speedLines.classList.remove('active');
        setIdle();
      }, 200);
    }

    if (isWalking) {
      walkFrame = (walkFrame + 0.055) % 1;
      applyWalkFrame(walkFrame);
    }
  });

  // ── 씬 카드 위치 ─────────────────────────────────────
  const cards = document.querySelectorAll('.scene-card');
  cards.forEach(card => {
    const xPct = parseFloat(card.dataset.x) / 100;
    card.style.left = (xPct * TRAVEL()) + 'px';
    ScrollTrigger.create({
      trigger: driver,
      start: 'top top',
      end: 'bottom bottom',
      onUpdate: (self) => {
        const screenX = parseFloat(card.style.left) - TRAVEL() * self.progress;
        const inView  = screenX > -100 && screenX < window.innerWidth * 0.75;
        card.querySelector('.card-inner').classList.toggle('visible', inView);
      }
    });
  });

  // ── 보물상자 위치 + 클릭 이벤트 ─────────────────────
  const chests = document.querySelectorAll('.chest-wrap');
  chests.forEach(chest => {
    const xPct  = parseFloat(chest.dataset.x) / 100;
    const idx   = parseInt(chest.dataset.chest);
    chest.style.left = (xPct * TRAVEL()) + 'px';
    chest.classList.add('positioned');

    // 상자 색상 목록
    const CHEST_COLORS = ['#ffaa00','#00ffff','#aa00ff','#00ff00'];

    // 클릭 / E키 공통 열기 함수
    function triggerOpen() {
      chest.classList.remove('opened');  // 매번 초기화로 재개방 허용
      const svg   = chest.querySelector('.chest-svg');
      const color = CHEST_COLORS[idx];

      // 뚜껑 열리는 SVG 조작: 뚜껑(첫 번째 rect)을 위로
      const lid = svg.querySelector('rect');

      // 빛 번쩍 엘리먼트 생성
      const flash = document.createElement('div');
      flash.style.cssText = `
        position:fixed; inset:0; pointer-events:none; z-index:8000;
        background: radial-gradient(circle at 50% 78%, ${color}44 0%, transparent 60%);
        opacity:0;
      `;
      document.body.appendChild(flash);

      // 시퀀스
      gsap.timeline()
        // 1. 상자 위로 튀어오름
        .to(svg, { y: -14, duration: 0.12, ease: 'power2.out' })
        // 2. 화면 빛 flash
        .to(flash, { opacity: 1, duration: 0.15, ease: 'power2.out' }, '-=0.05')
        // 3. 뚜껑 열림 (y 올라감)
        .to(lid,  { attr: { y: -12 }, duration: 0.2, ease: 'back.out(2)' }, '-=0.1')
        // 4. 상자 떨림
        .to(svg, { x: 4, duration: 0.05, yoyo: true, repeat: 5, ease: 'none' }, '-=0.1')
        // 5. 강한 glow
        .to(chest.querySelector('.chest-svg'), {
          filter: `drop-shadow(0 0 20px ${color}) drop-shadow(0 0 40px ${color})`,
          duration: 0.2
        }, '-=0.2')
        // 6. flash 페이드아웃
        .to(flash, { opacity: 0, duration: 0.4 })
        // 7. 모달 오픈
        .call(() => {
          chest.classList.add('opened');
          flash.remove();
          openModal(idx);
        });
    }

    chest.querySelector('.chest').addEventListener('click', triggerOpen);

    // E 키
    document.addEventListener('keydown', (e) => {
      if ((e.key === 'e' || e.key === 'E') && chest.classList.contains('near')) {
        triggerOpen();
      }
    });
  });

  // ── 리사이즈 대응 ─────────────────────────────────────
  ScrollTrigger.addEventListener('refreshInit', () => {
    cards.forEach(card => {
      const xPct = parseFloat(card.dataset.x) / 100;
      card.style.left = (xPct * TRAVEL()) + 'px';
    });
    chests.forEach(chest => {
      const xPct = parseFloat(chest.dataset.x) / 100;
      chest.style.left = (xPct * TRAVEL()) + 'px';
      chest.classList.add('positioned');
    });
  });

  // ── 입장 애니메이션 ───────────────────────────────────
  gsap.from('.hud-top',    { opacity: 0, y: -10, duration: 0.6, delay: 0.3 });
  gsap.from('.player-wrap',{ opacity: 0, scale: 0.5, duration: 0.5,
    ease: 'back.out(1.7)', delay: 0.5 });

  // ── 진입 안내 오버레이 ─────────────────────────────────
  const introOverlay  = document.getElementById('intro-overlay');
  const endingOverlay = document.getElementById('ending-overlay');
  const endingContent = document.getElementById('ending-content');
  let   introHidden   = false;
  let   endingShown   = false;

  // IntersectionObserver로 드라이버 가시성 감지
  const introObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !introHidden) {
        // 드라이버가 보이기 시작하면 즉시 intro 표시
        introOverlay.style.display = 'flex';
        gsap.set(introOverlay, { opacity: 0 });
        gsap.to(introOverlay, { opacity: 1, duration: 0.5 });
        gsap.fromTo(Array.from(introOverlay.children),
          { opacity: 0, y: 25 },
          { opacity: 1, y: 0, stagger: 0.18, duration: 0.6, ease: 'power2.out' }
        );
      }
    });
  }, { threshold: 0.05 });
  introObserver.observe(driver);

  // driver sticky 진입(스크롤 시작) 시 intro 숨김
  ScrollTrigger.create({
    trigger: driver,
    start: 'top top',
    onEnter: () => {
      introHidden = true;
      gsap.to(introOverlay, {
        opacity: 0, duration: 0.4,
        onComplete: () => { introOverlay.style.display = 'none'; }
      });
    },
    onLeaveBack: () => {
      // 스크롤 되돌아오면 다시 보여줌
      introHidden = false;
      introOverlay.style.display = 'flex';
      gsap.set(introOverlay, { opacity: 1 });
    }
  });

  // ── 스크롤 엔딩 ────────────────────────────────────────
  const endingFlash  = document.getElementById('ending-flash');
  const endingCanvas = document.getElementById('ending-canvas');

  // 픽셀 파티클 시스템
  function launchParticles() {
    const canvas = endingCanvas;
    canvas.style.display = 'block';
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    const ctx = canvas.getContext('2d');

    const COLORS = ['#00ff00','#00cc00','#33ff33','#ffffff','#ffff00','#00ffff'];
    const particles = Array.from({length: 120}, () => ({
      x: Math.random() * canvas.width,
      y: canvas.height * 0.8 + Math.random() * 50,
      vx: (Math.random() - 0.5) * 8,
      vy: -(Math.random() * 14 + 6),
      size: Math.floor(Math.random() * 6 + 3),  // 픽셀 느낌
      color: COLORS[Math.floor(Math.random() * COLORS.length)],
      life: 1,
      decay: Math.random() * 0.015 + 0.008,
      gravity: 0.25,
    }));

    let rafId;
    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let alive = false;
      particles.forEach(p => {
        if (p.life <= 0) return;
        alive = true;
        p.x  += p.vx;
        p.y  += p.vy;
        p.vy += p.gravity;
        p.vx *= 0.99;
        p.life -= p.decay;
        ctx.globalAlpha = Math.max(0, p.life);
        ctx.fillStyle = p.color;
        // 픽셀 파티클
        ctx.fillRect(Math.round(p.x), Math.round(p.y), p.size, p.size);
      });
      ctx.globalAlpha = 1;
      if (alive) rafId = requestAnimationFrame(draw);
      else { canvas.style.display = 'none'; cancelAnimationFrame(rafId); }
    }
    draw();
    return rafId;
  }

  // ── 엔딩: progress 0.92 이상이면 발동 ─────────────────────
  function fireEnding() {
    if (endingShown) return;
    endingShown = true;

    // 1단계: 화면 번쩍
    endingFlash.style.display = 'block';
    gsap.timeline()
      .to(endingFlash, { opacity: 1, duration: 0.15, ease: 'power3.in' })
      .to(endingFlash, { opacity: 0, duration: 0.8, ease: 'power2.out' })
      .call(() => { endingFlash.style.display = 'none'; });

    // 2단계: 파티클
    setTimeout(launchParticles, 80);

    // 3단계: 오버레이 + 텍스트
    setTimeout(() => {
      endingOverlay.style.display = 'flex';
      endingOverlay.style.background = 'rgba(0,0,0,0)';

      gsap.timeline()
        .to(endingOverlay, { background: 'rgba(0,0,0,0.85)', duration: 0.7 })
        .to(endingContent, { opacity: 1, duration: 0.1 }, '-=0.3')
        .fromTo('#ec-label',
          { opacity: 0, y: -16, scale: 0.8 },
          { opacity: 0.8, y: 0, scale: 1, duration: 0.45, ease: 'back.out(2)' }, '-=0.1'
        )
        .fromTo('#ec-title',
          { opacity: 0, scale: 1.35, filter: 'blur(16px)' },
          { opacity: 1, scale: 1, filter: 'blur(0px)', duration: 0.65, ease: 'power3.out' }
        )
        .to('#ec-title', { textShadow: '0 0 8px #00ff00', duration: 0.08 })
        .to('#ec-title', { textShadow: '0 0 20px #00ff00, 0 0 60px #00ff00, 0 0 120px #00ff00', duration: 0.3 })
        .fromTo('#ec-sub',
          { opacity: 0, y: 12 },
          { opacity: 1, y: 0, duration: 0.45, ease: 'power2.out' }, '-=0.1'
        )
        .fromTo('#ec-arrow', { opacity: 0 }, { opacity: 1, duration: 0.35 });
    }, 250);
  }

  function resetEnding() {
    endingShown = false;
    endingOverlay.style.display = 'none';
    endingFlash.style.display = 'none';
    endingCanvas.style.display = 'none';
    gsap.set(endingContent, { opacity: 0 });
    gsap.set([endingOverlay], { background: 'rgba(0,0,0,0)' });
    gsap.set('#ec-label,#ec-title,#ec-sub,#ec-arrow', { clearProps: 'all' });
  }

  // 메인 ScrollTrigger onUpdate에 progress 감지 추가
  ScrollTrigger.create({
    trigger: driver,
    start: 'top top',
    end: 'bottom bottom',
    onUpdate: (self) => {
      if (self.progress >= 0.92 && !endingShown) {
        fireEnding();
      }
      if (self.progress < 0.88 && endingShown) {
        resetEnding();
      }
    }
  });
});
</script>
<!-- ── Styles ───────────────────────────────────────────────── -->
<style>
  /* ── 드라이버: 세로 스크롤 공간 확보 ── */
  .scroll-driver {
    height: 500vh;   /* 이 높이 = 가로 이동 거리 */
    position: relative;
  }

  /* ── sticky 씬: 뷰포트에 고정 ── */
  .scroller-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: #000500;
    border-top: 2px solid #00ff00;
    border-bottom: 2px solid #00ff00;
  }

  /* ── 공통 레이어 ── */
  .layer {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    will-change: transform;
  }


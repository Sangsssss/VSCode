<style>
  /* ── 드라이버: 세로 스크롤 공간 확보 ── */
  .scroll-driver {
    height: 500vh;   /* 이 높이 = 가로 이동 거리 */
    position: relative;
  }

  /* ── sticky 씬: 뷰포트에 고정 ── */
  .scroller-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: #050d05;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  /* ── 공통 레이어 ── */
  .layer {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    will-change: transform;
  }

  /* 레이어 1: 하늘 */
  .layer-sky {
    bottom: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .stars {
    position: absolute;
    top: 0; left: 0;
    width: 200%; height: 70%;
  }
  .mountains-far {
    position: absolute;
    bottom: 22%;
    left: 0;
    width: 200%;
    height: 25%;
  }

  /* 레이어 2: 중경 빌딩 */
  .layer-mid {
    bottom: 0;
    height: 100%;
  }
  .buildings {
    position: absolute;
    bottom: 22%;
    left: 0;
    width: 300%;
    height: 45%;
  }

  /* 레이어 3: 바닥 */
  .layer-ground {
    bottom: 0;
    height: 22%;
  }
  .ground-svg {
    width: 550%;       /* TRAVEL=4vw * 1.00 이동 + 여유 1.5vw */
    height: 100%;
    position: absolute;
    bottom: 0; left: 0;
  }

  /* ── 씬 카드 ── */
  .scene-cards {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
  }
  .scene-card {
    position: absolute;
    top: 12%;
    pointer-events: all;
  }
  .card-inner {
    background: rgba(10,26,10,0.95);
    border: 1px solid var(--border);
    box-shadow: 0 0 40px rgba(0,255,0,0.2), inset 0 0 20px rgba(0,0,0,0.5);
    padding: 2.8rem 3.2rem;
    width: 380px;
    backdrop-filter: blur(6px);
    position: relative;
    clip-path: polygon(12px 0%, 100% 0%, calc(100% - 12px) 100%, 0% 100%);
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.4s, transform 0.4s;
  }
  .card-inner.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .card-year {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--text-muted);
    letter-spacing: 0.14em;
    margin-bottom: 0.7rem;
  }
  .card-title {
    font-family: var(--font-pixel);
    font-size: 1rem;
    color: var(--neon);
    text-shadow: 0 0 14px var(--neon);
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }
  .card-desc {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 2;
  }

  /* ── 플레이어 ── */
  .player-wrap {
    position: absolute;
    /* bottom=22% = 바닥선
       sprite height=192, 발 y=34/40*192=163px, 여백=29px
       margin-bottom:-29px → wrap이 바닥선 아래 29px까지 확장 → 발=바닥선 */
    bottom: 22%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    /* shadow를 absolute로 분리하므로 wrap = sprite만 */
    width: 144px;
    height: 192px;
    margin-bottom: -29px;
  }
  .player-sprite {
    width: 144px;
    height: 192px;
    image-rendering: pixelated;
    filter: drop-shadow(0 0 6px #00ff00) drop-shadow(0 0 14px #00cc00);
    display: block;
    position: relative;
    z-index: 1;
  }
  .player-shadow {
    position: absolute;
    bottom: 22px;   /* 발 여백(29px) 근처 */
    left: 50%;
    transform: translateX(-50%);
    width: 110px; height: 5px;
    background: radial-gradient(ellipse, rgba(0,255,0,0.5) 0%, transparent 70%);
    animation: shadow-pulse 0.5s ease-in-out infinite alternate;
    z-index: 0;
  }
  @keyframes shadow-pulse {
    from { transform: scaleX(1);   opacity: 0.5; }
    to   { transform: scaleX(0.7); opacity: 0.2; }
  }

  /* 워킹 애니메이션은 is:global 블록에서만 처리 */

  /* 스피드 라인 */
  .speed-lines {
    position: absolute;
    right: calc(100% + 8px);
    top: 30%;
    display: flex;
    flex-direction: column;
    gap: 5px;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .speed-lines.active { opacity: 1; }
  .speed-lines span {
    display: block;
    height: 2px;
    background: linear-gradient(to left, var(--neon), transparent);
    animation: speedline 0.25s linear infinite;
  }
  .speed-lines span:nth-child(1) { width: 28px; animation-delay: 0s;    }
  .speed-lines span:nth-child(2) { width: 18px; animation-delay: 0.05s; }
  .speed-lines span:nth-child(3) { width: 36px; animation-delay: 0.1s;  }
  .speed-lines span:nth-child(4) { width: 14px; animation-delay: 0.15s; }
  .speed-lines span:nth-child(5) { width: 24px; animation-delay: 0.2s;  }
  @keyframes speedline {
    from { transform: translateX(0);    opacity: 1; }
    to   { transform: translateX(-10px); opacity: 0; }
  }

  /* HUD */
  .hud-top {
    position: absolute;
    top: 1.2rem;
    left: 0; right: 0;

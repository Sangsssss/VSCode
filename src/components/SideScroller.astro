---
// src/components/SideScroller.astro
// Phase 2 — 횡스크롤 모험 엔진
---

<!-- 세로 스크롤 트리거용 래퍼 (높이가 가로 이동 거리를 결정) -->
<div class="scroll-driver" id="scroll-driver" data-section="game-world">

  <!-- 뷰포트에 고정되는 실제 씬 -->
  <div class="scroller-sticky" id="scroller-sticky">

    <!-- ── 배경 레이어 1: 별/성운 (가장 멀리, 가장 느리게) ── -->
    <div class="layer layer-sky" id="layer-sky">
      <!-- 별 SVG 패턴 -->
      <svg class="stars" viewBox="0 0 1600 400" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        {Array.from({length: 80}).map((_, i) => {
          const x = (i * 197 + 13) % 1600;
          const y = (i * 83  + 47) % 300;
          const r = i % 3 === 0 ? 2 : 1;
          const op = 0.3 + (i % 5) * 0.12;
          return <circle cx={x} cy={y} r={r} fill="#00ff00" opacity={op}/>;
        })}
        <!-- 성운 blob -->
        <ellipse cx="300"  cy="120" rx="180" ry="60" fill="rgba(0,255,0,0.03)"/>
        <ellipse cx="900"  cy="80"  rx="240" ry="80" fill="rgba(0,200,0,0.04)"/>
        <ellipse cx="1400" cy="150" rx="200" ry="70" fill="rgba(0,255,0,0.03)"/>
      </svg>

      <!-- 원거리 산 실루엣 -->
      <svg class="mountains-far" viewBox="0 0 1600 200" preserveAspectRatio="xMidYMax meet" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,200 L0,140 L80,80 L160,130 L280,40 L400,110 L520,60 L640,120 L760,30 L880,100 L1000,50 L1120,120 L1240,45 L1360,105 L1480,70 L1600,130 L1600,200 Z"
              fill="#0d1a0d" opacity="0.9"/>
      </svg>
    </div>

    <!-- ── 배경 레이어 2: 중경 도시 빌딩 (중간 속도) ── -->
    <div class="layer layer-mid" id="layer-mid">
      <svg class="buildings" viewBox="0 0 2400 300" preserveAspectRatio="xMidYMax meet" xmlns="http://www.w3.org/2000/svg">
        <!-- 빌딩들 -->
        {[
          {x:0,   w:60,  h:180}, {x:70,  w:40,  h:220}, {x:120, w:80,  h:150},
          {x:210, w:50,  h:260}, {x:270, w:70,  h:190}, {x:350, w:45,  h:240},
          {x:405, w:90,  h:160}, {x:505, w:55,  h:280}, {x:570, w:65,  h:200},
          {x:645, w:40,  h:170}, {x:695, w:85,  h:250}, {x:790, w:50,  h:130},
          {x:850, w:75,  h:270}, {x:935, w:45,  h:190}, {x:990, w:60,  h:220},
          {x:1060,w:80,  h:160}, {x:1150,w:55,  h:300}, {x:1215,w:70,  h:180},
          {x:1295,w:50,  h:240}, {x:1355,w:90,  h:140}, {x:1455,w:60,  h:260},
          {x:1525,w:45,  h:200}, {x:1580,w:75,  h:170}, {x:1665,w:55,  h:290},
          {x:1730,w:80,  h:150}, {x:1820,w:50,  h:230}, {x:1880,w:65,  h:180},
          {x:1955,w:70,  h:260}, {x:2035,w:45,  h:140}, {x:2090,w:90,  h:220},
          {x:2190,w:55,  h:190}, {x:2255,w:60,  h:270}, {x:2325,w:65,  h:160},
        ].map(b => (
          <g>
            <rect x={b.x} y={300-b.h} width={b.w} height={b.h} fill="#0a1a0a" stroke="rgba(0,255,0,0.15)" stroke-width="1"/>
            <!-- 창문 -->
            {Array.from({length: Math.floor(b.h/30)}).map((_, row) =>
              Array.from({length: Math.floor(b.w/20)}).map((_, col) => (
                <rect
                  x={b.x + 5 + col*18}
                  y={300 - b.h + 8 + row*28}
                  width="8" height="12"
                  fill={ (row + col + b.x) % 3 === 0 ? 'rgba(0,255,0,0.6)' : 'rgba(0,255,0,0.08)' }
                />
              ))
            )}
          </g>
        ))}
      </svg>
    </div>

    <!-- ── 배경 레이어 3: 바닥 + 근경 (가장 빠르게) ── -->
    <div class="layer layer-ground" id="layer-ground">
      <!-- 바닥 플랫폼 -->
      <svg class="ground-svg" viewBox="0 0 5500 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <!-- 바닥 라인 -->
        <rect x="0" y="0" width="5500" height="60" fill="#0a1a0a"/>
        <rect x="0" y="0" width="5500" height="2"  fill="#00ff00" opacity="0.9"/>
        <!-- 바닥 픽셀 패턴 -->
        {Array.from({length: 275}).map((_, i) => (
          <rect x={i*20} y="2" width="18" height="4" fill="rgba(0,255,0,0.12)"/>
        ))}
        <!-- 가로등 -->
        {[120,380,640,900,1160,1420,1680,1940,2200,2460,2720,2980,3240,3500,3760,4020,4280,4540,4800,5060,5300].map(x => (
          <g>
            <rect x={x}   y="0"  width="3"  height="20" fill="rgba(0,255,0,0.5)"/>
            <rect x={x-8} y="-16" width="20" height="4"  fill="rgba(0,255,0,0.4)"/>
            <rect x={x-4} y="-12" width="4"  height="4"  fill="#00ff00" opacity="0.9"/>
          </g>
        ))}
      </svg>
    </div>

    <!-- ── 스크롤 이벤트 카드들 ── -->
    <div class="scene-cards" id="scene-cards">

      <div class="scene-card" data-x="15">
        <div class="card-inner">
          <p class="card-year">2019</p>
          <h3 class="card-title">FIRST GAME</h3>
          <p class="card-desc">Unity로 만든 첫 번째 2D 플랫포머.<br/>무한한 가능성의 시작.</p>
        </div>
      </div>

      <div class="scene-card" data-x="38">
        <div class="card-inner">
          <p class="card-year">2021</p>
          <h3 class="card-title">GAME JAM</h3>
          <p class="card-desc">48시간 게임잼 우승.<br/>팀워크와 속도의 미학.</p>
        </div>
      </div>

      <div class="scene-card" data-x="61">
        <div class="card-inner">
          <p class="card-year">2022</p>
          <h3 class="card-title">SHADER CRAFT</h3>
          <p class="card-desc">HLSL 셰이더 깊이 탐구.<br/>빛과 픽셀의 연금술.</p>
        </div>
      </div>

      <div class="scene-card" data-x="84">
        <div class="card-inner">
          <p class="card-year">2024</p>
          <h3 class="card-title">UNREAL LEAP</h3>
          <p class="card-desc">Unreal Engine 5 전환.<br/>Nanite·Lumen 마스터.</p>
        </div>
      </div>

      <!-- ── 보물상자들 ── -->
      <div class="chest-wrap" data-x="22" data-chest="0">
        <div class="chest" data-hover>
          <svg class="chest-svg" viewBox="0 0 32 28" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">
            <!-- 뚜껑 -->
            <rect x="1" y="1" width="30" height="11" fill="#1a0a00" stroke="#ffaa00" stroke-width="1.5"/>
            <rect x="3" y="3" width="26" height="7"  fill="#2a1400"/>
            <rect x="12" y="2" width="8" height="3"  fill="#ffaa00" opacity="0.8"/>
            <!-- 경첩 -->
            <rect x="3"  y="10" width="4" height="3" fill="#ffaa00"/>
            <rect x="25" y="10" width="4" height="3" fill="#ffaa00"/>
            <!-- 몸통 -->
            <rect x="1" y="12" width="30" height="15" fill="#1a0a00" stroke="#ffaa00" stroke-width="1.5"/>
            <rect x="3" y="14" width="26" height="11" fill="#2a1400"/>
            <!-- 자물쇠 -->
            <rect x="13" y="13" width="6" height="5"  fill="#ffaa00"/>
            <rect x="14" y="11" width="4" height="4"  fill="none" stroke="#ffaa00" stroke-width="1.5"/>
            <!-- 장식 라인 -->
            <rect x="3" y="18" width="26" height="1"  fill="#ffaa00" opacity="0.4"/>
          </svg>
          <div class="chest-glow"></div>
        </div>
      </div>

      <div class="chest-wrap" data-x="45" data-chest="1">
        <div class="chest" data-hover>
          <svg class="chest-svg" viewBox="0 0 32 28" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">
            <rect x="1" y="1" width="30" height="11" fill="#001a1a" stroke="#00ffff" stroke-width="1.5"/>
            <rect x="3" y="3" width="26" height="7"  fill="#002a2a"/>
            <rect x="12" y="2" width="8" height="3"  fill="#00ffff" opacity="0.8"/>
            <rect x="3"  y="10" width="4" height="3" fill="#00ffff"/>
            <rect x="25" y="10" width="4" height="3" fill="#00ffff"/>
            <rect x="1" y="12" width="30" height="15" fill="#001a1a" stroke="#00ffff" stroke-width="1.5"/>
            <rect x="3" y="14" width="26" height="11" fill="#002a2a"/>
            <rect x="13" y="13" width="6" height="5"  fill="#00ffff"/>
            <rect x="14" y="11" width="4" height="4"  fill="none" stroke="#00ffff" stroke-width="1.5"/>
            <rect x="3" y="18" width="26" height="1"  fill="#00ffff" opacity="0.4"/>
          </svg>
          <div class="chest-glow chest-glow-cyan"></div>
        </div>
      </div>

      <div class="chest-wrap" data-x="67" data-chest="2">
        <div class="chest" data-hover>
          <svg class="chest-svg" viewBox="0 0 32 28" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">
            <rect x="1" y="1" width="30" height="11" fill="#0a001a" stroke="#aa00ff" stroke-width="1.5"/>
            <rect x="3" y="3" width="26" height="7"  fill="#16002a"/>
            <rect x="12" y="2" width="8" height="3"  fill="#aa00ff" opacity="0.8"/>
            <rect x="3"  y="10" width="4" height="3" fill="#aa00ff"/>
            <rect x="25" y="10" width="4" height="3" fill="#aa00ff"/>
            <rect x="1" y="12" width="30" height="15" fill="#0a001a" stroke="#aa00ff" stroke-width="1.5"/>
            <rect x="3" y="14" width="26" height="11" fill="#16002a"/>
            <rect x="13" y="13" width="6" height="5"  fill="#aa00ff"/>
            <rect x="14" y="11" width="4" height="4"  fill="none" stroke="#aa00ff" stroke-width="1.5"/>
            <rect x="3" y="18" width="26" height="1"  fill="#aa00ff" opacity="0.4"/>
          </svg>
          <div class="chest-glow chest-glow-purple"></div>
        </div>
      </div>

      <div class="chest-wrap" data-x="88" data-chest="3">
        <div class="chest" data-hover>
          <svg class="chest-svg" viewBox="0 0 32 28" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">
            <rect x="1" y="1" width="30" height="11" fill="#001a00" stroke="#00ff00" stroke-width="1.5"/>
            <rect x="3" y="3" width="26" height="7"  fill="#002a00"/>
            <rect x="12" y="2" width="8" height="3"  fill="#00ff00" opacity="0.8"/>
            <rect x="3"  y="10" width="4" height="3" fill="#00ff00"/>
            <rect x="25" y="10" width="4" height="3" fill="#00ff00"/>
            <rect x="1" y="12" width="30" height="15" fill="#001a00" stroke="#00ff00" stroke-width="1.5"/>
            <rect x="3" y="14" width="26" height="11" fill="#002a00"/>
            <rect x="13" y="13" width="6" height="5"  fill="#00ff00"/>
            <rect x="14" y="11" width="4" height="4"  fill="none" stroke="#00ff00" stroke-width="1.5"/>
            <rect x="3" y="18" width="26" height="1"  fill="#00ff00" opacity="0.4"/>
          </svg>
          <div class="chest-glow"></div>
        </div>
      </div>

    </div>

    <!-- ── 중앙 고정 캐릭터 ── -->
    <div class="player-wrap" id="player-wrap">
      <svg class="player-sprite" id="player-sprite"
           viewBox="0 0 28 40" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">

        <!-- 뒷다리 (먼저 그려서 앞다리에 가려짐) -->
        <rect id="leg-b"  x="9"  y="22" width="5" height="10" fill="#006600"/>
        <rect id="foot-b" x="7"  y="30" width="8" height="4"  fill="#004400"/>

        <!-- 뒷팔 -->
        <rect id="arm-b"  x="6"  y="12" width="4" height="9"  fill="#006600"/>

        <!-- 몸통 -->
        <rect x="8"  y="10" width="12" height="13" fill="#00dd00"/>
        <!-- 몸통 안쪽 (갑옷 느낌) -->
        <rect x="9"  y="11" width="10" height="11" fill="#00aa00"/>
        <!-- 배지/문양 -->
        <rect x="11" y="13" width="6"  height="4"  fill="#0a1a0a"/>
        <rect x="12" y="14" width="4"  height="2"  fill="#00ff00"/>

        <!-- 머리: 오른쪽 방향으로 향함 -->
        <!-- 뒷통수 -->
        <rect x="8"  y="1"  width="4"  height="9"  fill="#00cc00"/>
        <!-- 머리 메인 -->
        <rect x="10" y="0"  width="12" height="10" fill="#00ff00"/>
        <!-- 얼굴 안쪽 -->
        <rect x="11" y="1"  width="10" height="8"  fill="#0a1a0a"/>
        <!-- 눈 (오른쪽 방향) -->
        <rect x="19" y="3"  width="2"  height="2"  fill="#00ff00"/>
        <!-- 눈빛 -->
        <rect x="20" y="3"  width="1"  height="1"  fill="#ffffff"/>
        <!-- 입 -->
        <rect x="19" y="6"  width="3"  height="1"  fill="#00cc00"/>
        <!-- 코 -->
        <rect x="21" y="4"  width="2"  height="2"  fill="#00aa00"/>
        <!-- 헬멧 바이저 -->
        <rect x="10" y="0"  width="12" height="3"  fill="#00cc00"/>
        <rect x="18" y="2"  width="4"  height="2"  fill="#00ff00"/>

        <!-- 앞팔 -->
        <rect id="arm-f"  x="18" y="12" width="4" height="9"  fill="#00ee00"/>

        <!-- 앞다리 -->
        <rect id="leg-f"  x="11" y="22" width="5" height="10" fill="#00cc00"/>
        <rect id="foot-f" x="11" y="30" width="8" height="4"  fill="#009900"/>
      </svg>

      <!-- 그림자 (SVG 아래) -->
      <div class="player-shadow"></div>

      <!-- 스크롤 중 표시되는 속도 이펙트 -->
      <div class="speed-lines" id="speed-lines">
        <span></span><span></span><span></span>
        <span></span><span></span>
      </div>
    </div>

    <!-- HUD 오버레이 -->
    <div class="hud-top">
      <span class="hud-label">WORLD 1-1</span>
      <span class="hud-progress" id="hud-progress">▓░░░░░░░░░ 0%</span>
      <span class="hud-label">SCROLL TO WALK →</span>
    </div>

  </div>
</div>

<!-- ── 게임 진입 안내 오버레이 ── -->
<div id="intro-overlay" style="
  display:none;
  position:fixed; inset:0; z-index:8500;
  background: rgba(0,0,0,0.82);
  backdrop-filter: blur(4px);
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  pointer-events: all;
">
  <div style="
    font-family: 'Press Start 2P', monospace;
    font-size: 0.65rem;
    color: rgba(0,255,0,0.5);
    letter-spacing: 0.2em;
    animation: blink-slow 1.5s step-end infinite;
  ">// WORLD LOADING...</div>
  <div style="
    font-family: 'Press Start 2P', monospace;
    font-size: 1.1rem;
    color: #00ff00;
    text-shadow: 0 0 20px #00ff00, 0 0 40px #00ff00;
    letter-spacing: 0.12em;
    text-align: center;
    line-height: 2.2;
  ">DREAM_HERO<br/>ENTERED THE WORLD</div>
  <div style="
    font-family: 'Share Tech Mono', monospace;
    font-size: 1rem;
    color: #aaa;
    text-align: center;
    line-height: 2;
    max-width: 480px;
  ">아래로 스크롤하면 플레이어가 움직입니다.<br/>이동 중 만나는 상자에 접근하면<br/><span style="color:#00ff00">[ E ]</span> 키로 열어보세요!</div>
  <div style="
    font-family: 'Press Start 2P', monospace;
    font-size: 0.6rem;
    color: #555;
    letter-spacing: 0.2em;
    margin-top: 1rem;
    animation: blink-slow 1s step-end infinite;
  ">▼ SCROLL TO START ▼</div>
</div>

<!-- ── 스크롤 엔딩 오버레이 ── -->
<!-- 엔딩: 화면 전체 flash 레이어 -->
<div id="ending-flash" style="
  display:none; position:fixed; inset:0; z-index:8400;
  pointer-events:none; opacity:0;
  background: radial-gradient(circle at 50% 78%, #00ff00 0%, #003300 40%, #000 100%);
"></div>

<!-- 엔딩: 파티클 캔버스 -->
<canvas id="ending-canvas" style="
  display:none; position:fixed; inset:0; z-index:8450;
  pointer-events:none;
"></canvas>

<!-- 엔딩: 텍스트 오버레이 -->
<div id="ending-overlay" style="
  display:none;
  position:fixed; inset:0; z-index:8500;
  background: rgba(0,0,0,0);
  pointer-events: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rem;
">
  <div id="ending-content" style="
    display:flex; flex-direction:column; align-items:center; gap:2rem;
    opacity:0; text-align:center;
  ">
    <!-- 스테이지 클리어 라벨 -->
    <div id="ec-label" style="
      font-family: 'Press Start 2P', monospace;
      font-size: 0.65rem;
      color: #00ff00;
      letter-spacing: 0.4em;
      opacity:0.7;
    ">✦ STAGE CLEAR ✦</div>

    <!-- 메인 타이틀 -->
    <div id="ec-title" style="
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(1.2rem, 3vw, 2rem);
      color: #00ff00;
      text-shadow: 0 0 20px #00ff00, 0 0 50px #00ff00, 0 0 100px #00ff00;
      letter-spacing: 0.2em;
      line-height: 1.8;
    ">WORLD 1-1<br/>COMPLETE!</div>

    <!-- 구분선 -->
    <div style="width:280px; height:1px; background: linear-gradient(to right, transparent, #00ff00, transparent);"></div>

    <!-- 서브 텍스트 -->
    <div id="ec-sub" style="
      font-family: 'Share Tech Mono', monospace;
      font-size: 1.05rem;
      color: #aaa;
      line-height: 2.2;
    ">상자를 열어 프로젝트를 확인하셨나요?<br/>스크롤을 올려 다시 탐험하거나<br/>아래로 계속 진행하세요.</div>

    <!-- 계속 화살표 -->
    <div id="ec-arrow" style="
      font-family: 'Press Start 2P', monospace;
      font-size: 0.6rem;
      color: #444;
      letter-spacing: 0.2em;
      animation: blink-slow 1.2s step-end infinite;
    ">▼ CONTINUE ▼</div>
  </div>
</div>

<style is:global>
  @keyframes blink-slow {
    0%,100%{opacity:1} 50%{opacity:0}
  }
  @keyframes scanline-move {
    from { background-position: 0 0; }
    to   { background-position: 0 4px; }
  }
</style>

<!-- ── 전역 툴팁 (scroller-sticky 완전 바깥) ── -->
<div id="chest-tip-wrap" style="display:none; position:fixed; z-index:9000; pointer-events:none;">
  <div id="chest-tip-label" style="
    font-family: 'Press Start 2P', monospace;
    font-size: 0.75rem;
    color: #ffaa00;
    text-shadow: 0 0 10px #ffaa00;
    background: rgba(0,0,0,0.92);
    padding: 0.5rem 1.2rem;
    border: 1px solid rgba(255,170,0,0.6);
    white-space: nowrap;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    text-align: center;
  "></div>
  <div id="chest-tip-e" style="
    font-family: 'Press Start 2P', monospace;
    font-size: 0.85rem;
    color: #00ff00;
    text-shadow: 0 0 10px #00ff00;
    background: rgba(0,0,0,0.95);
    border: 2px solid #00ff00;
    box-shadow: 0 0 16px rgba(0,255,0,0.5);
    padding: 0.8rem 2rem;
    letter-spacing: 0.12em;
    white-space: nowrap;
    text-align: center;
    animation: tip-pulse 1s ease-in-out infinite alternate;
  ">[ E ] 열어보기</div>
</div>
<style is:global>
  @keyframes tip-pulse {
    from { box-shadow: 0 0 10px rgba(0,255,0,0.4); }
    to   { box-shadow: 0 0 28px rgba(0,255,0,0.9); }
  }
</style>

<!-- ── 프로젝트 모달 (scroll-driver 완전 바깥 — position:fixed 독립) ── -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal-window" id="modal-window">

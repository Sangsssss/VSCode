    console.log('[Modal] opening:', p.name, overlay);
    overlay.classList.add('open');
    // body overflow hidden 제거 — 스크롤 씬에서 충돌 방지
    // document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.remove('open');
  }

  closeBtn.addEventListener('click', closeModal);
  closeBtnG.addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ── 패럴랙스 ScrollTrigger ───────────────────────────
  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: driver,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 1,
      onUpdate: (self) => {
        const p = self.progress;

        // HUD 진행바
        const pct    = Math.round(p * 100);
        const filled = Math.round(p * 10);
        const bar    = '▓'.repeat(filled) + '░'.repeat(10 - filled);
        hudProg.textContent = `${bar} ${pct}%`;

        // HUD만 onUpdate에서 처리 (walking은 ticker로 분리)

        // 보물상자 근접 감지 + 전역 툴팁 위치 제어
        const chests = document.querySelectorAll('.chest-wrap');
        const tipWrap = document.getElementById('chest-tip-wrap');
        const tipLabel = document.getElementById('chest-tip-label');
        const tipE     = document.getElementById('chest-tip-e');
        const CHEST_NAMES = ['VOID RUNNER', 'NEON SIEGE', 'ECHO PROTOCOL', 'PIXEL CRUSADE'];

        let anyNear = false;
        chests.forEach(chest => {
          const chestScreenX = parseFloat(chest.style.left || 0) - TRAVEL() * p;
          const playerX = window.innerWidth * 0.5;
          const dist = Math.abs(chestScreenX - playerX);
          const isNear = dist < 120;
          chest.classList.toggle('near', isNear);

          if (isNear) {
            anyNear = true;
            const idx = parseInt(chest.dataset.chest);
            // 상자 화면 중심 X
            const cx = chestScreenX + 44;
            // 바닥 라인 Y (scroller-sticky top=0, height=100vh, ground=22%)
            const groundY = window.innerHeight * 0.78;
            // 상자 높이 76px → 상자 상단 Y
            const chestTop = groundY - 76;
            tipLabel.textContent = CHEST_NAMES[idx];
            // 툴팁을 상자 위 중앙에 배치
            tipWrap.style.display   = 'flex';
            tipWrap.style.flexDirection = 'column';
            tipWrap.style.alignItems = 'center';
            tipWrap.style.left      = cx + 'px';
            tipWrap.style.top       = (chestTop - 90) + 'px';
            tipWrap.style.transform = 'translateX(-50%)';
          }
        });

        if (!anyNear) {
          tipWrap.style.display = 'none';
        }
      },
    }
  });

  tl.to(layerSky,   { x: () => -TRAVEL() * 0.18, ease: 'none' }, 0)
    .to(layerMid,   { x: () => -TRAVEL() * 0.50, ease: 'none' }, 0)
    .to(layerGnd,   { x: () => -TRAVEL() * 1.00, ease: 'none' }, 0)
    .to(sceneCards, { x: () => -TRAVEL() * 1.00, ease: 'none' }, 0);

  // ── 워킹 애니메이션: 측면뷰 — x/y 좌표 직접 조작 ─────────────
  const playerWrap = document.getElementById('player-wrap');

  // 측면뷰 요소들
  const legF  = document.getElementById('leg-f');
  const legB  = document.getElementById('leg-b');
  const footF = document.getElementById('foot-f');
  const footB = document.getElementById('foot-b');
  const armF  = document.getElementById('arm-f');
  const armB  = document.getElementById('arm-b');

  // idle 기준값 (새 SVG viewBox 28x40 기준)
  const BASE = {
    legF:  { x:13, y:27 }, legB:  { x:10, y:27 },
    footF: { x:13, y:37 }, footB: { x:7,  y:37 },
    armF:  { x:20, y:16 }, armB:  { x:5,  y:16 },
  };

  let walkFrame   = 0;
  let isWalking   = false;
  let lastScrollY = window.scrollY;
  let stopTimer   = null;

  function setIdle() {
    legF.setAttribute('x',  BASE.legF.x);  legF.setAttribute('y',  BASE.legF.y);
    legB.setAttribute('x',  BASE.legB.x);  legB.setAttribute('y',  BASE.legB.y);
    footF.setAttribute('x', BASE.footF.x); footF.setAttribute('y', BASE.footF.y);
    footB.setAttribute('x', BASE.footB.x); footB.setAttribute('y', BASE.footB.y);
    armF.setAttribute('x',  BASE.armF.x);  armF.setAttribute('y',  BASE.armF.y);
    armB.setAttribute('x',  BASE.armB.x);  armB.setAttribute('y',  BASE.armB.y);
  }

  function applyWalkFrame(t) {
    const s = Math.sin(t * Math.PI * 2); // -1 ~ 1

    // 앞다리: 앞으로 나갈 때 x+, 발 들어올림 y-
    const lfX = Math.round(BASE.legF.x + s * 4);
    const lfY = Math.round(BASE.legF.y - Math.max(0, s) * 6);
    legF.setAttribute('x', lfX);
    legF.setAttribute('y', lfY);
    footF.setAttribute('x', lfX);
    footF.setAttribute('y', Math.round(BASE.footF.y - Math.max(0, s) * 5));

    // 뒷다리: 반대 위상
    const lbX = Math.round(BASE.legB.x - s * 4);
    const lbY = Math.round(BASE.legB.y - Math.max(0, -s) * 6);
    legB.setAttribute('x', lbX);
    legB.setAttribute('y', lbY);
    footB.setAttribute('x', lbX - 1);
    footB.setAttribute('y', Math.round(BASE.footB.y - Math.max(0, -s) * 5));

    // 앞팔: 다리 반대로 (뒤로 가면 팔은 앞으로)
    armF.setAttribute('y', Math.round(BASE.armF.y + s * 3));
    // 뒷팔: 앞팔 반대
    armB.setAttribute('y', Math.round(BASE.armB.y - s * 3));
  }

  // 매 프레임
  gsap.ticker.add(() => {
    const currentY = window.scrollY;
    const delta    = Math.abs(currentY - lastScrollY);
    lastScrollY    = currentY;

    if (delta > 0.3) {
      isWalking = true;
      speedLines.classList.add('active');
      clearTimeout(stopTimer);
      stopTimer = setTimeout(() => {
        isWalking = false;
        speedLines.classList.remove('active');
        setIdle();
      }, 200);
    }

    if (isWalking) {
      walkFrame = (walkFrame + 0.055) % 1;
      applyWalkFrame(walkFrame);
    }
  });

  // ── 씬 카드 위치 ─────────────────────────────────────
  const cards = document.querySelectorAll('.scene-card');
  cards.forEach(card => {
    const xPct = parseFloat(card.dataset.x) / 100;
    card.style.left = (xPct * TRAVEL()) + 'px';
    ScrollTrigger.create({
      trigger: driver,
      start: 'top top',
      end: 'bottom bottom',
      onUpdate: (self) => {
        const screenX = parseFloat(card.style.left) - TRAVEL() * self.progress;
        const inView  = screenX > -100 && screenX < window.innerWidth * 0.75;
        card.querySelector('.card-inner').classList.toggle('visible', inView);
      }
    });
  });

  // ── 보물상자 위치 + 클릭 이벤트 ─────────────────────
  const chests = document.querySelectorAll('.chest-wrap');
  chests.forEach(chest => {
    const xPct  = parseFloat(chest.dataset.x) / 100;
    const idx   = parseInt(chest.dataset.chest);
    chest.style.left = (xPct * TRAVEL()) + 'px';
    chest.classList.add('positioned');

    // 상자 색상 목록
    const CHEST_COLORS = ['#ffaa00','#00ffff','#aa00ff','#00ff00'];

    // 클릭 / E키 공통 열기 함수
    function triggerOpen() {
      chest.classList.remove('opened');  // 매번 초기화로 재개방 허용
      const svg   = chest.querySelector('.chest-svg');
      const color = CHEST_COLORS[idx];

      // 뚜껑 열리는 SVG 조작: 뚜껑(첫 번째 rect)을 위로
      const lid = svg.querySelector('rect');

      // 빛 번쩍 엘리먼트 생성
      const flash = document.createElement('div');
      flash.style.cssText = `
        position:fixed; inset:0; pointer-events:none; z-index:8000;
        background: radial-gradient(circle at 50% 78%, ${color}44 0%, transparent 60%);
        opacity:0;
      `;
      document.body.appendChild(flash);

      // 시퀀스
      gsap.timeline()
        // 1. 상자 위로 튀어오름
        .to(svg, { y: -14, duration: 0.12, ease: 'power2.out' })
        // 2. 화면 빛 flash
        .to(flash, { opacity: 1, duration: 0.15, ease: 'power2.out' }, '-=0.05')
        // 3. 뚜껑 열림 (y 올라감)
        .to(lid,  { attr: { y: -12 }, duration: 0.2, ease: 'back.out(2)' }, '-=0.1')
        // 4. 상자 떨림
        .to(svg, { x: 4, duration: 0.05, yoyo: true, repeat: 5, ease: 'none' }, '-=0.1')
        // 5. 강한 glow
        .to(chest.querySelector('.chest-svg'), {
          filter: `drop-shadow(0 0 20px ${color}) drop-shadow(0 0 40px ${color})`,
          duration: 0.2
        }, '-=0.2')
        // 6. flash 페이드아웃
        .to(flash, { opacity: 0, duration: 0.4 })
        // 7. 모달 오픈
        .call(() => {
          chest.classList.add('opened');
          flash.remove();
          openModal(idx);
        });
    }

    chest.querySelector('.chest').addEventListener('click', triggerOpen);

    // E 키
    document.addEventListener('keydown', (e) => {
      if ((e.key === 'e' || e.key === 'E') && chest.classList.contains('near')) {
        triggerOpen();
      }
    });
  });

  // ── 리사이즈 대응 ─────────────────────────────────────
  ScrollTrigger.addEventListener('refreshInit', () => {
    cards.forEach(card => {
      const xPct = parseFloat(card.dataset.x) / 100;
      card.style.left = (xPct * TRAVEL()) + 'px';
    });
    chests.forEach(chest => {
      const xPct = parseFloat(chest.dataset.x) / 100;
      chest.style.left = (xPct * TRAVEL()) + 'px';
      chest.classList.add('positioned');
    });
  });

  // ── 입장 애니메이션 ───────────────────────────────────
  gsap.from('.hud-top',    { opacity: 0, y: -10, duration: 0.6, delay: 0.3 });
  gsap.from('.player-wrap',{ opacity: 0, scale: 0.5, duration: 0.5,
    ease: 'back.out(1.7)', delay: 0.5 });

  // ── 진입 안내 오버레이 ─────────────────────────────────
  const introOverlay  = document.getElementById('intro-overlay');
  const endingOverlay = document.getElementById('ending-overlay');
  const endingContent = document.getElementById('ending-content');
  let   introHidden   = false;
  let   endingShown   = false;

  // driver가 화면에 들어올 때(아래로 스크롤) → intro 표시
  // driver sticky 진입 시 → intro 숨김
  // driver가 화면에서 완전히 벗어날 때(위로) → intro 즉시 숨김
  ScrollTrigger.create({
    trigger: driver,
    start: 'top bottom',   // driver 상단이 뷰포트 하단에 닿는 순간
    end: 'top top',        // driver 상단이 뷰포트 상단에 닿는 순간
    onEnter: () => {
      // 아래로 스크롤: driver 진입 → intro 표시
      if (!introHidden) {
        introOverlay.style.display = 'flex';
        gsap.set(introOverlay, { opacity: 0 });
        gsap.to(introOverlay, { opacity: 1, duration: 0.4 });
        gsap.fromTo(Array.from(introOverlay.children),
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, stagger: 0.15, duration: 0.5, ease: 'power2.out' }
        );
      }
    },
    onLeave: () => {
      // 아래로 스크롤: driver sticky 진입 → intro 숨김
      introHidden = true;
      gsap.to(introOverlay, {
        opacity: 0, duration: 0.35,
        onComplete: () => { introOverlay.style.display = 'none'; }
      });
    },
    onEnterBack: () => {
      // 위로 스크롤: sticky 벗어남 → intro 다시 표시
      introHidden = false;
      introOverlay.style.display = 'flex';
      gsap.set(introOverlay, { opacity: 1 });
    },
    onLeaveBack: () => {
      // 위로 스크롤: driver 완전히 위로 벗어남 → 즉시 숨김
      introHidden = false;
      gsap.killTweensOf(introOverlay);
      introOverlay.style.display = 'none';
      gsap.set(introOverlay, { opacity: 0 });
    }
  });

  // ── 스크롤 엔딩 ────────────────────────────────────────
  const endingFlash  = document.getElementById('ending-flash');
  const endingCanvas = document.getElementById('ending-canvas');

  // 픽셀 파티클 시스템
  function launchParticles() {
    const canvas = endingCanvas;
    canvas.style.display = 'block';
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    const ctx = canvas.getContext('2d');

    const COLORS = ['#00ff00','#00cc00','#33ff33','#ffffff','#ffff00','#00ffff'];
    const particles = Array.from({length: 120}, () => ({
      x: Math.random() * canvas.width,
      y: canvas.height * 0.8 + Math.random() * 50,
      vx: (Math.random() - 0.5) * 8,
      vy: -(Math.random() * 14 + 6),
      size: Math.floor(Math.random() * 6 + 3),  // 픽셀 느낌
      color: COLORS[Math.floor(Math.random() * COLORS.length)],
      life: 1,
      decay: Math.random() * 0.015 + 0.008,
      gravity: 0.25,
    }));

    let rafId;
    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let alive = false;
      particles.forEach(p => {
        if (p.life <= 0) return;
        alive = true;
        p.x  += p.vx;
        p.y  += p.vy;
        p.vy += p.gravity;
        p.vx *= 0.99;
        p.life -= p.decay;
        ctx.globalAlpha = Math.max(0, p.life);
        ctx.fillStyle = p.color;
        // 픽셀 파티클
        ctx.fillRect(Math.round(p.x), Math.round(p.y), p.size, p.size);
      });
      ctx.globalAlpha = 1;
      if (alive) rafId = requestAnimationFrame(draw);
      else { canvas.style.display = 'none'; cancelAnimationFrame(rafId); }
    }
    draw();
    return rafId;
  }

  // ── 엔딩: progress 0.92 이상이면 발동 ─────────────────────
  function fireEnding() {
    if (endingShown) return;
    endingShown = true;

    // 1단계: 화면 번쩍
    endingFlash.style.display = 'block';
    gsap.timeline()
      .to(endingFlash, { opacity: 1, duration: 0.15, ease: 'power3.in' })
      .to(endingFlash, { opacity: 0, duration: 0.8, ease: 'power2.out' })
      .call(() => { endingFlash.style.display = 'none'; });

    // 2단계: 파티클
    setTimeout(launchParticles, 80);

    // 3단계: 오버레이 + 텍스트
    setTimeout(() => {
      endingOverlay.style.display = 'flex';
      endingOverlay.style.background = 'rgba(0,0,0,0)';

      gsap.timeline()
        .to(endingOverlay, { background: 'rgba(0,0,0,0.85)', duration: 0.7 })
        .to(endingContent, { opacity: 1, duration: 0.1 }, '-=0.3')
        .fromTo('#ec-label',
          { opacity: 0, y: -16, scale: 0.8 },
          { opacity: 0.8, y: 0, scale: 1, duration: 0.45, ease: 'back.out(2)' }, '-=0.1'
        )
        .fromTo('#ec-title',
          { opacity: 0, scale: 1.35, filter: 'blur(16px)' },
          { opacity: 1, scale: 1, filter: 'blur(0px)', duration: 0.65, ease: 'power3.out' }
        )
        .to('#ec-title', { textShadow: '0 0 8px #00ff00', duration: 0.08 })
        .to('#ec-title', { textShadow: '0 0 20px #00ff00, 0 0 60px #00ff00, 0 0 120px #00ff00', duration: 0.3 })
        .fromTo('#ec-sub',
          { opacity: 0, y: 12 },
          { opacity: 1, y: 0, duration: 0.45, ease: 'power2.out' }, '-=0.1'
        )
        .fromTo('#ec-arrow', { opacity: 0 }, { opacity: 1, duration: 0.35 });
    }, 250);
  }

  function resetEnding() {
    endingShown = false;
    endingOverlay.style.display = 'none';
    endingFlash.style.display = 'none';
    endingCanvas.style.display = 'none';
    gsap.set(endingContent, { opacity: 0 });
    gsap.set([endingOverlay], { background: 'rgba(0,0,0,0)' });
    gsap.set('#ec-label,#ec-title,#ec-sub,#ec-arrow', { clearProps: 'all' });
  }

  // progress 기반 엔딩 감지
  ScrollTrigger.create({
    trigger: driver,
    start: 'top top',
    end: 'bottom bottom',
    onUpdate: (self) => {
      if (self.progress >= 0.92 && !endingShown) {
        fireEnding();
      }
      if (self.progress < 0.88 && endingShown) {
        resetEnding();
      }
    },
    onLeave: () => {
      // driver 끝을 지나 아래로 완전히 나가면 엔딩 오버레이 숨김
      // (Contact 등 다음 섹션이 보이게)
      gsap.to(endingOverlay, {
        opacity: 0, duration: 0.5,
        onComplete: () => {
          endingOverlay.style.display = 'none';
          endingCanvas.style.display  = 'none';
        }
      });
    },
    onEnterBack: () => {
      // 다시 driver 안으로 돌아오면 엔딩 재표시
      if (endingShown) {
        endingOverlay.style.display = 'flex';
        gsap.to(endingOverlay, { opacity: 1, duration: 0.4 });
      }
    }
  });
});
</script>
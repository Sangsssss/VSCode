        <text x="28" y="78" font-family="monospace" font-size="9" fill="#00ff00" opacity="0.6">WORKOUT_MODE.exe</text>
      `,
    },
    soccer: {
      title: '⚽ FIELD HACKER',
      desc:  '피치 위에서도 전략과 포지셔닝.\n팀플레이는 협업 개발과 닮았습니다.',
      img: '/images/trait-soccer.jpg',
      svgBg: `
        <!-- 축구공 픽셀아트 -->
        <circle cx="60" cy="42" r="28" fill="#002200" stroke="#00ff00" stroke-width="1.5"/>
        <rect x="53" y="22" width="14" height="8"  fill="#00ff00" opacity="0.6"/>
        <rect x="36" y="34" width="8"  height="14" fill="#00ff00" opacity="0.6"/>
        <rect x="76" y="34" width="8"  height="14" fill="#00ff00" opacity="0.6"/>
        <rect x="42" y="54" width="10" height="8"  fill="#00ff00" opacity="0.6"/>
        <rect x="68" y="54" width="10" height="8"  fill="#00ff00" opacity="0.6"/>
        <rect x="58" y="30" width="4"  height="24" fill="#003300"/>
        <rect x="48" y="40" width="24" height="4"  fill="#003300"/>
        <text x="18" y="78" font-family="monospace" font-size="9" fill="#00ff00" opacity="0.6">TEAM_STRATEGY.run()</text>
      `,
    },
    blog: {
      title: '✍️ DEV LOGGER',
      desc:  '배운 것을 글로 남기는 개발자.\n기록은 미래의 나에게 보내는 코드리뷰.',
      img: '/images/trait-blog.jpg',
      svgBg: `
        <!-- 노트북/블로그 픽셀아트 -->
        <rect x="20" y="20" width="80" height="52" fill="#001800" stroke="#00ff00" stroke-width="1.5"/>
        <rect x="22" y="22" width="76" height="44" fill="#000e00"/>
        <rect x="22" y="22" width="76" height="4"  fill="#003300"/>
        <rect x="26" y="30" width="40" height="2"  fill="#00ff00" opacity="0.85"/>
        <rect x="26" y="34" width="30" height="2"  fill="#00ff00" opacity="0.65"/>
        <rect x="26" y="38" width="50" height="2"  fill="#00ff00" opacity="0.75"/>
        <rect x="26" y="42" width="35" height="2"  fill="#00ff00" opacity="0.55"/>
        <rect x="26" y="46" width="45" height="2"  fill="#00ff00" opacity="0.7"/>
        <rect x="26" y="50" width="20" height="2"  fill="#00ff00" opacity="0.5"/>
        <!-- 커서 깜박 -->
        <rect x="48" y="50" width="6"  height="2"  fill="#00ff00"/>
        <text x="22" y="78" font-family="monospace" font-size="9" fill="#00ff00" opacity="0.6">git push origin blog</text>
      `,
    },
    jam: {
      title: '🎮 JAM VETERAN',
      desc:  '게임잼 참가 3회. 48시간 안에 세계를 만드는 경험.\n제약이 창의성을 폭발시킵니다.',
      img: '/images/trait-jam.jpg',
      svgBg: `
        <!-- 게임패드 픽셀아트 -->
        <rect x="22" y="28" width="76" height="40" rx="12" fill="#001800" stroke="#00ff00" stroke-width="1.5"/>
        <rect x="30" y="35" width="14" height="4"  fill="#004400"/>
        <rect x="36" y="29" width="4"  height="14" fill="#004400"/>
        <rect x="76" y="33" width="6"  height="6"  fill="#00ff00" opacity="0.7"/>
        <rect x="84" y="33" width="6"  height="6"  fill="#00ff00" opacity="0.4"/>
        <rect x="80" y="29" width="6"  height="6"  fill="#00ff00" opacity="0.4"/>
        <rect x="80" y="37" width="6"  height="6"  fill="#00ff00" opacity="0.4"/>
        <rect x="54" y="43" width="12" height="10" rx="4" fill="#003300" stroke="#00cc00" stroke-width="1"/>
        <text x="26" y="78" font-family="monospace" font-size="9" fill="#00ff00" opacity="0.6">JAM_COUNT: 3 WINS</text>
      `,
    },
  };

  const popup     = document.getElementById('trait-popup');
  const popTitle  = document.getElementById('trait-title');
  const popDesc   = document.getElementById('trait-desc');
  const popImg    = document.getElementById('trait-img');
  const popSvg    = document.getElementById('trait-placeholder');
  const popClose  = document.getElementById('trait-close');

  document.querySelectorAll('.chip[data-trait]').forEach(chip => {
    chip.addEventListener('click', () => {
      const key  = chip.dataset.trait;
      const data = TRAITS[key];
      if (!data) return;

      popTitle.textContent = data.title;
      popDesc.textContent  = data.desc;

      // 실제 이미지 시도
      popImg.style.display = 'none';
      popSvg.style.display = 'block';
      popSvg.innerHTML = `<rect x="0" y="0" width="120" height="90" fill="#020a02"/>${data.svgBg}`;

      const img = new Image();
      img.onload = () => {
        popImg.src = data.img;
        popImg.style.display = 'block';
        popSvg.style.display = 'none';
      };
      img.onerror = () => { /* SVG 유지 */ };
      img.src = data.img;

      popup.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    });
  });

  function closePopup() {
    popup.style.display = 'none';
    document.body.style.overflow = '';
  }
  popClose.addEventListener('click', closePopup);
  popup.addEventListener('click', e => { if (e.target === popup) closePopup(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closePopup(); });
</script>
  /* ── Profile Panel ── */
  .profile-panel {
    padding: 2rem 1.5rem;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    background: rgba(0,255,0,0.02);
  }

  .sprite-frame {
    position: relative;
    width: 240px; height: 330px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pixel-char {
    width: 240px; height: 330px;  /* viewBox 64:88 비율 */
    image-rendering: pixelated;
    filter: drop-shadow(0 0 12px #00ff00) drop-shadow(0 0 28px #00cc00) drop-shadow(0 0 50px rgba(0,255,0,0.35));
    animation: float 3s ease-in-out infinite;
    position: relative;
    z-index: 2;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }
  .sprite-scan {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px, transparent 3px,
      rgba(0,255,0,0.04) 3px, rgba(0,255,0,0.04) 4px
    );
    pointer-events: none;
    z-index: 3;
  }
  .sprite-ring {
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 80px; height: 16px;
    background: radial-gradient(ellipse, rgba(0,255,0,0.3) 0%, transparent 70%);
    animation: pulse-ring 3s ease-in-out infinite;
    z-index: 1;
  }
  @keyframes pulse-ring {
    0%, 100% { opacity: 0.4; transform: translateX(-50%) scaleX(1); }
    50%       { opacity: 0.8; transform: translateX(-50%) scaleX(1.2); }
  }

  .profile-class {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);

<!-- ── GSAP Animations ──────────────────────────────────────── -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {

    /* ── 패널 전체 등장 ── */
    const tl = gsap.timeline({ delay: 0.3 });

    tl.from('.window-bar', { opacity: 0, y: -10, duration: 0.4, ease: 'power2.out' })
      .from('.profile-panel', { opacity: 0, x: -30, duration: 0.5, ease: 'power2.out' }, '-=0.1')
      .from('.stats-panel',   { opacity: 0, x:  30, duration: 0.5, ease: 'power2.out' }, '-=0.4')
      .from('.start-wrap',    { opacity: 0, y:  20, duration: 0.4, ease: 'power2.out' }, '-=0.1');

    /* ── 스탯 바 애니메이션 (ScrollTrigger) ── */
    document.querySelectorAll('.stat-fill').forEach((bar, i) => {
      const target = bar.dataset.val + '%';
      ScrollTrigger.create({
        trigger: bar,
        start: 'top 90%',
        onEnter: () => {
          gsap.to(bar, {
            width: target,
            duration: 1.0,
            delay: i * 0.08,
            ease: 'power2.out',
          });
        },
        once: true,
      });
    });

    /* ── 숫자 카운트업 ── */
    document.querySelectorAll('.stat-num').forEach((el, i) => {
      const end = parseInt(el.textContent);
      el.textContent = '0';
      ScrollTrigger.create({
        trigger: el,
        start: 'top 90%',
        onEnter: () => {
          const obj = { val: 0 };
          gsap.to(obj, {
            val: end,
            duration: 1.0,
            delay: i * 0.08,
            ease: 'power2.out',
            onUpdate: () => { el.textContent = Math.round(obj.val); },
          });
        },
        once: true,
      });
    });

    /* ── PASSIVE SKILL CARDS JS ── */
    (() => {
      document.querySelectorAll('.sk-card').forEach((card, ci) => {
        const scan  = card.querySelector('.sk-scan');
        const lines = card.querySelectorAll('.sk-slot,.sk-codename,.sk-line,.sk-bar-label');

        // 진입 시: 텍스트 숨김 → 스캔 레이저 → 텍스트 순차 등장
        ScrollTrigger.create({
          trigger: card,
          start: 'top 88%',
          onEnter: () => {
            gsap.set(lines, { opacity: 0 });
            gsap.fromTo(scan,
              { top: '-4px', opacity: 0.95 },
              {
                top: '110%', opacity: 0,
                duration: 0.65, delay: ci * 0.12, ease: 'none',
                onComplete: () => {
                  gsap.to(lines, { opacity: 1, duration: 0.04, stagger: 0.05, ease: 'none' });
                }
              }
            );
          },
          once: true,
        });

        // 호버: 스캔 레이저 재실행 + 카드 테두리 순간 플래시
        card.addEventListener('mouseenter', () => {
          gsap.fromTo(scan,
            { top: '-4px', opacity: 0.9 },
            { top: '110%', opacity: 0, duration: 0.4, ease: 'none' }
          );
          // 테두리 글로우 플래시
          gsap.fromTo(card,
            { filter: 'brightness(1.8)' },
            { filter: 'brightness(1)', duration: 0.5, ease: 'power2.out' }
          );
        });
      });

      // 글리치 (코드네임 랜덤)
      const codeNames = document.querySelectorAll('.sk-codename');
      setInterval(() => {
        const el = codeNames[Math.floor(Math.random() * codeNames.length)];
        if (!el) return;
        el.style.animation = 'sk-glitch 0.15s steps(1) forwards';
        setTimeout(() => { el.style.animation = ''; }, 200);
      }, 3500);
    })();

    /* ── 픽셀 캐릭터 등장 ── */
    gsap.from('.pixel-char', {
      opacity: 0,
      scale: 0.5,
      duration: 0.6,
      ease: 'back.out(1.7)',
      delay: 0.6,
    });

    /* ── GAME START 버튼 → 다음 섹션 스크롤 ── */
    document.getElementById('game-start-btn')?.addEventListener('click', () => {
      // SideScroller 섹션으로 이동
      const gameWorld = document.getElementById('scroll-driver');
      if (gameWorld) {
        // 버튼 클릭 이펙트
        const btn = document.getElementById('game-start-btn');
        gsap.to(btn, { scale: 0.95, duration: 0.1, yoyo: true, repeat: 1 });

        // 화면 플래시 효과
        const flash = document.createElement('div');
        flash.style.cssText = 'position:fixed;inset:0;background:#00ff00;z-index:9999;pointer-events:none;';
        document.body.appendChild(flash);
        gsap.to(flash, {
          opacity: 0,
          duration: 0.5,
          ease: 'power2.out',
          onComplete: () => flash.remove()
        });

        // 스크롤 이동
        setTimeout(() => {
          gsap.to(window, {
            scrollTo: { y: gameWorld, offsetY: 0 },
            duration: 1.0,
            ease: 'power3.inOut',
          });
        }, 150);
      }
    });

  });

  // ── 트레잇 칩 팝업 ─────────────────────────────────────
  const TRAITS = {
    gym: {

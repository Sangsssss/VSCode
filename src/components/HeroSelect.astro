  /* Main sheet body */
  .sheet-body {
    display: grid;
    grid-template-columns: 340px 40px 1fr;
    border: 1px solid var(--border);
    background: rgba(10,10,10,0.95);
    box-shadow: 0 0 40px rgba(0,255,0,0.07), inset 0 0 60px rgba(0,0,0,0.6);

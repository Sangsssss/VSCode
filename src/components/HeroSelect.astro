---
// src/components/HeroSelect.astro
// Phase 1 — 캐릭터 시트 (자기소개)
---

<section class="hero-select" id="about">

  <!-- 상단 타이틀 바 -->
  <div class="window-bar">
    <span class="window-dot"></span>
    <span class="window-dot"></span>
    <span class="window-dot"></span>
    <span class="window-title">CHARACTER_SELECT</span>
    <span class="window-version">VER 1.0.0</span>
  </div>

  <div class="sheet-body">

    <!-- ── 왼쪽: 캐릭터 프로필 ── -->
    <div class="profile-panel">

      <!-- 픽셀 아트 캐릭터 (SVG) -->
      <div class="sprite-frame">
        <svg class="pixel-char" viewBox="0 0 64 88" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">

          <!-- ═══ 고양이 귀 ═══ -->
          <rect x="16" y="2"  width="2"  height="6"  fill="#00ff00"/>
          <rect x="18" y="2"  width="2"  height="4"  fill="#00ff00"/>
          <rect x="16" y="2"  width="4"  height="2"  fill="#00ff00"/>
          <rect x="17" y="3"  width="2"  height="4"  fill="#002200"/>
          <rect x="46" y="2"  width="2"  height="6"  fill="#00ff00"/>
          <rect x="44" y="2"  width="2"  height="4"  fill="#00ff00"/>
          <rect x="44" y="2"  width="4"  height="2"  fill="#00ff00"/>
          <rect x="45" y="3"  width="2"  height="4"  fill="#002200"/>

          <!-- ═══ 헤드폰 밴드 ═══ -->
          <rect x="18" y="7"  width="28" height="3"  fill="#00bb00"/>
          <rect x="19" y="8"  width="26" height="1"  fill="#007700"/>
          <!-- 왼쪽 컵 -->
          <rect x="11" y="15" width="8"  height="11" fill="#00aa00"/>
          <rect x="12" y="16" width="6"  height="9"  fill="#001800"/>
          <rect x="13" y="17" width="4"  height="7"  fill="#002500"/>
          <!-- 오른쪽 컵 -->
          <rect x="45" y="15" width="8"  height="11" fill="#00aa00"/>
          <rect x="46" y="16" width="6"  height="9"  fill="#001800"/>
          <rect x="47" y="17" width="4"  height="7"  fill="#002500"/>

          <!-- ═══ 머리 ═══ -->
          <rect x="17" y="8"  width="30" height="22" fill="#00ff00"/>
          <rect x="19" y="9"  width="26" height="20" fill="#00ee00"/>
          <!-- 머리카락 -->
          <rect x="17" y="8"  width="30" height="5"  fill="#003300"/>
          <rect x="19" y="9"  width="26" height="4"  fill="#004400"/>
          <!-- 머리 옆면 어두움 -->
          <rect x="17" y="8"  width="3"  height="22" fill="#00cc00"/>
          <rect x="44" y="8"  width="3"  height="22" fill="#00cc00"/>

          <!-- ═══ 안경 ═══ -->
          <!-- 왼쪽 프레임 -->
          <rect x="19" y="18" width="11" height="8"  fill="#001200"/>
          <rect x="19" y="18" width="11" height="1"  fill="#00ff00"/>
          <rect x="19" y="25" width="11" height="1"  fill="#00ff00"/>
          <rect x="19" y="18" width="1"  height="8"  fill="#00ff00"/>
          <rect x="29" y="18" width="1"  height="8"  fill="#00ff00"/>
          <rect x="21" y="20" width="7"  height="4"  fill="#001800"/>
          <rect x="21" y="20" width="2"  height="2"  fill="#00ff00" opacity="0.45"/>
          <!-- 오른쪽 프레임 -->
          <rect x="34" y="18" width="11" height="8"  fill="#001200"/>
          <rect x="34" y="18" width="11" height="1"  fill="#00ff00"/>
          <rect x="34" y="25" width="11" height="1"  fill="#00ff00"/>
          <rect x="34" y="18" width="1"  height="8"  fill="#00ff00"/>
          <rect x="44" y="18" width="1"  height="8"  fill="#00ff00"/>
          <rect x="36" y="20" width="7"  height="4"  fill="#001800"/>
          <rect x="36" y="20" width="2"  height="2"  fill="#00ff00" opacity="0.45"/>
          <!-- 코받침 -->
          <rect x="30" y="21" width="4"  height="1"  fill="#00cc00"/>
          <!-- 사이드 안경다리 -->
          <rect x="14" y="19" width="5"  height="1"  fill="#00cc00"/>
          <rect x="45" y="19" width="5"  height="1"  fill="#00cc00"/>

          <!-- ═══ 눈 ═══ -->
          <rect x="21" y="20" width="7"  height="4"  fill="#00ff00"/>
          <rect x="36" y="20" width="7"  height="4"  fill="#00ff00"/>
          <rect x="23" y="21" width="3"  height="2"  fill="#002200"/>
          <rect x="38" y="21" width="3"  height="2"  fill="#002200"/>
          <rect x="24" y="21" width="1"  height="1"  fill="#00ff00"/>
          <rect x="39" y="21" width="1"  height="1"  fill="#00ff00"/>

          <!-- ═══ 코 ═══ -->
          <rect x="30" y="24" width="4"  height="2"  fill="#00cc00"/>
          <rect x="31" y="25" width="2"  height="1"  fill="#009900"/>

          <!-- ═══ 입 ═══ -->
          <rect x="25" y="27" width="14" height="2"  fill="#009900"/>
          <rect x="24" y="27" width="1"  height="1"  fill="#00cc00"/>
          <rect x="39" y="27" width="1"  height="1"  fill="#00cc00"/>
          <rect x="26" y="26" width="12" height="1"  fill="#00dd00"/>

          <!-- ═══ 목 ═══ -->
          <rect x="26" y="30" width="12" height="6"  fill="#00ee00"/>
          <rect x="27" y="31" width="10" height="4"  fill="#00dd00"/>

          <!-- ═══ 몸통 ═══ -->
          <rect x="14" y="36" width="36" height="24" fill="#0d0d0d"/>
          <!-- 네온 외곽선 -->
          <rect x="14" y="36" width="36" height="2"  fill="#00dd00"/>
          <rect x="14" y="58" width="36" height="2"  fill="#00dd00"/>
          <rect x="14" y="36" width="2"  height="24" fill="#00dd00"/>
          <rect x="48" y="36" width="2"  height="24" fill="#00dd00"/>
          <!-- 어깨 -->
          <rect x="16" y="38" width="32" height="2"  fill="#00aa00"/>

          <!-- ═══ 팔 ═══ -->
          <rect x="4"  y="36" width="10" height="20" fill="#0d0d0d"/>
          <rect x="4"  y="36" width="10" height="2"  fill="#00dd00"/>
          <rect x="4"  y="36" width="2"  height="20" fill="#00dd00"/>
          <rect x="50" y="36" width="10" height="20" fill="#0d0d0d"/>
          <rect x="50" y="36" width="10" height="2"  fill="#00dd00"/>
          <rect x="58" y="36" width="2"  height="20" fill="#00dd00"/>

          <!-- ═══ 손 ═══ -->
          <rect x="3"  y="55" width="12" height="9"  fill="#00ee00"/>
          <rect x="4"  y="56" width="10" height="7"  fill="#00cc00"/>
          <rect x="5"  y="57" width="8"  height="5"  fill="#00bb00"/>
          <rect x="49" y="55" width="12" height="9"  fill="#00ee00"/>
          <rect x="50" y="56" width="10" height="7"  fill="#00cc00"/>
          <rect x="51" y="57" width="8"  height="5"  fill="#00bb00"/>

          <!-- ═══ 노트북 ═══ -->
          <rect x="18" y="40" width="28" height="20" fill="#00aa00"/>
          <rect x="19" y="41" width="26" height="16" fill="#000e00"/>
          <!-- 화면 상단 줄 -->
          <rect x="19" y="41" width="26" height="2"  fill="#003300"/>
          <!-- 코드 라인 -->
          <rect x="21" y="44" width="14" height="1"  fill="#00ff00" opacity="0.95"/>
          <rect x="23" y="46" width="10" height="1"  fill="#00ff00" opacity="0.75"/>
          <rect x="21" y="48" width="16" height="1"  fill="#00ff00" opacity="0.85"/>
          <rect x="23" y="50" width="8"  height="1"  fill="#00ff00" opacity="0.65"/>
          <rect x="21" y="52" width="12" height="1"  fill="#00ff00" opacity="0.75"/>
          <rect x="23" y="54" width="9"  height="1"  fill="#00ff00" opacity="0.55"/>
          <!-- < 기호 -->
          <rect x="38" y="44" width="1"  height="1"  fill="#00ff00"/>
          <rect x="37" y="45" width="1"  height="1"  fill="#00ff00"/>
          <rect x="37" y="46" width="1"  height="1"  fill="#00ff00"/>
          <rect x="38" y="47" width="1"  height="1"  fill="#00ff00"/>
          <!-- <> 기호 -->
          <rect x="37" y="50" width="1"  height="1"  fill="#00ff00"/>
          <rect x="38" y="51" width="1"  height="1"  fill="#00ff00"/>
          <rect x="37" y="52" width="1"  height="1"  fill="#00ff00"/>
          <rect x="39" y="51" width="1"  height="1"  fill="#00ff00"/>
          <rect x="40" y="50" width="1"  height="1"  fill="#00ff00"/>
          <rect x="41" y="51" width="1"  height="1"  fill="#00ff00"/>
          <rect x="40" y="52" width="1"  height="1"  fill="#00ff00"/>
          <!-- 하단 베젤 -->
          <rect x="18" y="57" width="28" height="3"  fill="#007700"/>
          <!-- dev 텍스트 -->
          <rect x="20" y="58" width="7"  height="1"  fill="#00ff00" opacity="0.7"/>
          <!-- 노트북 받침 -->
          <rect x="17" y="60" width="30" height="2"  fill="#005500"/>

          <!-- ═══ 다리 ═══ -->
          <rect x="18" y="62" width="12" height="17" fill="#00bb00"/>
          <rect x="19" y="63" width="10" height="15" fill="#00aa00"/>
          <rect x="34" y="62" width="12" height="17" fill="#00bb00"/>
          <rect x="35" y="63" width="10" height="15" fill="#00aa00"/>

          <!-- ═══ 발 ═══ -->
          <rect x="15" y="77" width="16" height="5"  fill="#008800"/>
          <rect x="16" y="78" width="14" height="3"  fill="#006600"/>
          <rect x="33" y="77" width="16" height="5"  fill="#008800"/>
          <rect x="34" y="78" width="14" height="3"  fill="#006600"/>

        </svg>
        <!-- 스캔 라인 오버레이 -->
        <div class="sprite-scan"></div>
        <!-- 빛나는 링 -->
        <div class="sprite-ring"></div>
      </div>

      <!-- 캐릭터 기본 정보 -->
      <div class="profile-info">
        <p class="profile-class">// NICKNAME</p>
        <h2 class="profile-name">SANGS</h2>
        <div class="profile-tags">
          <span class="tag">PROGRAMMER</span>
          <span class="tag">CREATOR</span>
        </div>
        <div class="profile-meta">
          <div class="meta-row">
            <span class="meta-label">AGE</span>
            <span class="meta-val neon-text">26</span>
          </div>
          <div class="meta-row">
            <span class="meta-label">EXP</span>
            <span class="meta-val">7+ YRS</span>
          </div>
          <div class="meta-row">
            <span class="meta-label">CLASS</span>
            <span class="meta-val">ENGINEER</span>
          </div>
          <div class="meta-row">
            <span class="meta-label">GUILD</span>
            <span class="meta-val">INDIE</span>
          </div>
        </div>

        <!-- 자기소개 -->
        <div class="profile-bio">
          <p class="bio-label">// BIO</p>
          <p class="bio-text">게임을 만드는 것은 세계를 만드는 일입니다.<br/>
          플레이어가 몰입할 수 있는 경험을 설계하고,<br/>
          코드와 아트가 만나는 접점에서 작업합니다.</p>
          <div class="bio-stats">
            <div class="bio-stat"><span class="bio-num neon-text">5</span><span>GAMES</span></div>
            <div class="bio-stat"><span class="bio-num neon-text">5+</span><span>YEARS XP</span></div>
          </div>
        </div>

      </div>

    </div>

    <!-- ── 구분선 ── -->
    <div class="divider">
      <div class="divider-line"></div>
      <span class="divider-icon">⚔</span>
      <div class="divider-line"></div>
    </div>

    <!-- ── 오른쪽: 능력치 패널 ── -->
    <div class="stats-panel">

      <p class="stats-header">// ABILITY STATS</p>

      <div class="stats-list">
        {[
          { name: "C++",        val: 88, rank: "S" },
          { name: "C#",         val: 95, rank: "S+" },
          { name: "Unity",      val: 92, rank: "S" },
          { name: "Unreal",     val: 78, rank: "A" },
          { name: "HLSL/GLSL",  val: 72, rank: "A" },
          { name: "Game Design",val: 85, rank: "S" },
          { name: "Godot",      val: 65, rank: "B+" },
        ].map(stat => (
          <div class="stat-row">
            <div class="stat-head">
              <span class="stat-name">{stat.name}</span>
              <span class={`stat-rank rank-${stat.rank.replace('+','p')}`}>{stat.rank}</span>
            </div>
            <div class="stat-track">
              <div class="stat-fill" data-val={stat.val}></div>
              <!-- 픽셀 눈금 -->
              <div class="tick" style="left:10%"></div>
              <div class="tick" style="left:20%"></div>
              <div class="tick" style="left:30%"></div>
              <div class="tick" style="left:40%"></div>
              <div class="tick" style="left:50%"></div>
              <div class="tick" style="left:60%"></div>
              <div class="tick" style="left:70%"></div>
              <div class="tick" style="left:80%"></div>
              <div class="tick" style="left:90%"></div>
            </div>
            <span class="stat-num">{stat.val}</span>
          </div>
        ))}
      </div>

      <!-- 학력 / 경력 — 패시브 스킬 카드 -->
      <div class="history">
        <div class="history-header">
          <p class="history-label">// PASSIVE_SKILLS LOADED</p>
        </div>

        <!-- 가로 3열 그리드 -->
        <div class="skill-cards">

          <!-- CARD 1: 명지대 -->
          <div class="sk-card edu-card" data-skill="edu">
            <!-- 스캔 레이저 -->
            <div class="sk-scan"></div>
            <!-- 코너 HEX -->
            <!-- 아이콘 & 슬롯명 -->
            <div class="sk-header">
              <span class="sk-icon">🎓</span>
              <div>
                <p class="sk-slot">PASSIVE SLOT #01</p>
                <p class="sk-codename">ORIGIN: THE ACADEMIA</p>
              </div>
            </div>
            <!-- 설명 -->
            <div class="sk-body">
              <p class="sk-line"><span class="sk-key">BASE_CLASS</span><span class="sk-val">학사 학위</span></p>
              <p class="sk-line"><span class="sk-key">SOURCE_CODE</span><span class="sk-val">응용소프트웨어전공</span></p>
              <p class="sk-line"><span class="sk-key">INSTITUTE</span><span class="sk-val">명지대학교</span></p>
              <p class="sk-line"><span class="sk-key">PERIOD</span><span class="sk-val">2018.03 – 2024.02</span></p>
            </div>
            <!-- 충전 바 -->
            <div class="sk-bar-wrap">
              <div class="sk-bar-track">
                <div class="sk-bar-fill edu-fill" data-w="100" style="width:100%"></div>
              </div>
              <span class="sk-bar-label">SKILL_LV MAX</span>
            </div>
          </div>

          <!-- CARD 2: 경일게임아카데미 -->
          <div class="sk-card boot-card" data-skill="boot">
            <div class="sk-scan"></div>
            <div class="sk-header">
              <span class="sk-icon">⚡</span>
              <div>
                <p class="sk-slot">PASSIVE SLOT #02</p>
                <p class="sk-codename">EXP BOOST: VR/AR MASTER</p>
              </div>
            </div>
            <div class="sk-body">
              <p class="sk-line"><span class="sk-key">SESSION_TYPE</span><span class="sk-val">특수 스킬 트레이닝</span></p>
              <p class="sk-line"><span class="sk-key">SPEC</span><span class="sk-val">VR/AR 게임개발</span></p>
              <p class="sk-line"><span class="sk-key">INSTITUTE</span><span class="sk-val">경일게임아카데미</span></p>
              <p class="sk-line"><span class="sk-key">PERIOD</span><span class="sk-val">2024.03 – 2024.11</span></p>
            </div>
            <div class="sk-bar-wrap">
              <div class="sk-bar-track">
                <div class="sk-bar-fill boot-fill" data-w="100" style="width:100%"></div>
              </div>
              <span class="sk-bar-label">XP_BOOST +340%</span>
            </div>
          </div>

          <!-- CARD 3: 군복무 -->
          <div class="sk-card mil-card" data-skill="mil">
            <div class="sk-scan"></div>
            <div class="sk-header">
              <span class="sk-icon">🎖</span>
              <div>
                <p class="sk-slot">PASSIVE SLOT #03</p>
                <p class="sk-codename">PHYSICAL HARDENING: COMPLETE</p>
              </div>
            </div>
            <div class="sk-body">
              <p class="sk-line"><span class="sk-key">QUEST_TYPE</span><span class="sk-val">방어력 강화 퀘스트</span></p>
              <p class="sk-line"><span class="sk-key">UNIT</span><span class="sk-val">1사단 17포병대대</span></p>
              <p class="sk-line"><span class="sk-key">RANK</span><span class="sk-val">병장 만기전역</span></p>
              <p class="sk-line"><span class="sk-key">STATUS</span><span class="sk-val edu-val">✔ COMPLETED</span></p>
            </div>
            <div class="sk-bar-wrap">
              <div class="sk-bar-track">
                <div class="sk-bar-fill mil-fill" data-w="100" style="width:100%"></div>
              </div>
              <span class="sk-bar-label">DEF +999 / MIND +999</span>
            </div>
          </div>

        </div>
        <!-- 시스템 상태 표시줄 -->
        <div class="history-status">
          <span class="hs-dot"></span>
          <span class="hs-text">SYSTEM_STATUS: OPTIMAL</span>
          <span class="hs-sep">|</span>
          <span class="hs-text" id="hs-tick">PASSIVE_SKILLS: 3/3 LOADED</span>
        </div>
      </div>

      <!-- 특성 칩 -->
      <div class="traits">
        <p class="traits-label">// TRAITS</p>
        <div class="traits-chips">
          <span class="chip" data-trait="gym">💪 IRON PROTOCOL</span>
          <span class="chip" data-trait="soccer">⚽ FIELD HACKER</span>
          <span class="chip" data-trait="blog">✍️ DEV LOGGER</span>
          <span class="chip" data-trait="jam">🎮 JAM VETERAN</span>
        </div>
      </div>

      <!-- 트레잇 이미지 팝업 -->
      <div id="trait-popup" style="display:none; position:fixed; inset:0; z-index:9500; background:rgba(0,0,0,0.85); backdrop-filter:blur(6px); align-items:center; justify-content:center; flex-direction:column; gap:1.5rem;">
        <div style="position:relative; border:2px solid #00ff00; box-shadow:0 0 30px rgba(0,255,0,0.5); max-width:420px; width:90%;">
          <div style="background:#050d05; padding:0.6rem 1rem; border-bottom:1px solid rgba(0,255,0,0.3); display:flex; justify-content:space-between; align-items:center;">
            <span id="trait-title" style="font-family:'Press Start 2P',monospace; font-size:0.6rem; color:#00ff00; letter-spacing:0.1em;"></span>
            <button id="trait-close" style="background:none; border:none; color:#00ff00; font-size:1.2rem; cursor:pointer; line-height:1;">✕</button>
          </div>
          <div id="trait-img-wrap" style="width:100%; aspect-ratio:4/3; background:#020a02; display:flex; align-items:center; justify-content:center; overflow:hidden; position:relative;">
            <!-- 이미지가 없을 때 픽셀아트 플레이스홀더 -->
            <svg id="trait-placeholder" viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges" style="width:160px; opacity:0.7;"></svg>
            <img id="trait-img" src="" alt="" style="width:100%; height:100%; object-fit:cover; display:none;"/>
          </div>
          <div id="trait-desc" style="background:#050d05; padding:0.8rem 1rem; font-family:'Share Tech Mono',monospace; font-size:0.85rem; color:#888; line-height:1.7; white-space:pre-line;"></div>
        </div>
        <p style="font-family:'Press Start 2P',monospace; font-size:0.5rem; color:#333; letter-spacing:0.2em; animation: blink-txt 1s step-end infinite;">[ CLICK ANYWHERE TO CLOSE ]</p>
      </div>

    </div>

  </div>

  <!-- ── GAME START 버튼 ── -->
  <div class="start-wrap">
    <button class="btn-start" id="game-start-btn" data-hover>
      <span class="btn-arrow">▶</span>
      <span class="btn-label">GAME START</span>
      <span class="btn-blink">█</span>
    </button>
    <p class="start-hint">PRESS START TO CONTINUE</p>
  </div>

</section>

<!-- ── Styles ──────────────────────────────────────────────── -->
<style>
  .hero-select {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 2rem 6vw 4rem;
    position: relative;
  }

  /* Window title bar */
  .window-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: rgba(0,255,0,0.06);
    border: 1px solid var(--border);
    border-bottom: none;
    margin-bottom: 0;
    width: fit-content;
    min-width: 340px;
  }
  .window-dot {
    width: 11px; height: 11px;
    background: var(--neon);
    box-shadow: 0 0 4px var(--neon);
    display: inline-block;
  }
  .window-title {
    font-family: var(--font-pixel);
    font-size: 0.65rem;
    color: var(--neon);
    margin-left: 0.5rem;
    letter-spacing: 0.08em;
  }
  .window-version {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);

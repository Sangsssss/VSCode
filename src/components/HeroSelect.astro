      // 이미지 경로: /images/trait-gym.jpg 로 업로드하면 자동 표시
      img: '/images/trait-gym.jpg',
      svgBg: `
        <!-- 덤벨 픽셀아트 -->
        <rect x="20" y="38" width="80" height="14" fill="#003300"/>
        <rect x="10" y="30" width="20" height="30" fill="#004400"/>
        <rect x="90" y="30" width="20" height="30" fill="#004400"/>
        <rect x="14" y="26" width="12" height="8"  fill="#00ff00" opacity="0.5"/>
        <rect x="14" y="56" width="12" height="8"  fill="#00ff00" opacity="0.5"/>
        <rect x="94" y="26" width="12" height="8"  fill="#00ff00" opacity="0.5"/>
        <rect x="94" y="56" width="12" height="8"  fill="#00ff00" opacity="0.5"/>

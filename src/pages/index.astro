---
import Layout from '../layouts/Layout.astro';
import HeroSelect from '../components/HeroSelect.astro';
import SideScroller from '../components/SideScroller.astro';
---

<Layout title="PLAYER_ONE — Game Developer Portfolio">

  <!-- ── HERO ───────────────────────────────────────────── -->
  <HeroSelect />
  <SideScroller />
 

  <!-- ── CONTACT ────────────────────────────────────────── -->
  <section id="contact" class="section">
    <h2 class="section-title gsap-fade-in"><span class="neon-text">02.</span> CONTACT</h2>
    <p class="contact-lead gsap-fade-in">새로운 모험을 함께할 팀원을 찾고 있습니다.<br/>언제든지 메시지를 보내주세요.</p>

    <div class="contact-grid gsap-fade-in">
      <!-- 이메일 주소 표시 -->
      <div class="contact-info">
        <p class="contact-label">// EMAIL</p>
        <a href="mailto:your@email.com" class="contact-email">dltkddnjsas@gmail.com</a>
      </div>

      <!-- 메시지 폼 -->
      <div class="contact-form-wrap">
        <p class="contact-label">// SEND_MESSAGE()</p>
        <div class="contact-form">
          <div class="form-field">
            <label class="form-label">NAME_</label>
            <input type="text" id="cf-name" class="form-input" placeholder="PLAYER_ONE"/>
          </div>
          <div class="form-field">
            <label class="form-label">EMAIL_</label>
            <input type="email" id="cf-email" class="form-input" placeholder="your@email.com"/>
          </div>
          <div class="form-field">
            <label class="form-label">MESSAGE_</label>
            <textarea id="cf-msg" class="form-input form-textarea" placeholder="HELLO WORLD..."></textarea>
          </div>
          <button id="cf-submit" class="btn-primary contact-btn" data-hover>
            <span class="btn-icon">✉</span>
            <span id="cf-label">SEND MESSAGE</span>
            <span class="btn-blink">█</span>
          </button>
          <p id="cf-status" class="cf-status"></p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<!-- ── Page-level styles ─────────────────────────────────── -->
<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 10vw;
    position: relative;
  }
  .hero-sub {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    letter-spacing: 0.1em;
  }
  .hero-title {
    font-family: var(--font-pixel);
    font-size: clamp(2rem, 7vw, 5.5rem);
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }
  .hero-title .line1 { display: block; color: var(--text); }
  .hero-title .line2 { display: block; }
  .hero-desc {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    margin-bottom: 3rem;
  }
  .hero-cta { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .blink-cursor {
    position: absolute;
    bottom: 2rem; left: 10vw;
    font-family: var(--font-pixel);
    font-size: 1.2rem;
    color: var(--neon);
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  /* Buttons */
  .btn-primary {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    padding: 0.9rem 2rem;
    background: var(--neon);
    color: var(--bg);
    text-decoration: none;
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
    transition: box-shadow 0.2s, background 0.2s;
  }
  .btn-primary:hover {
    background: #33ff33;
    box-shadow: 0 0 20px var(--neon-glow);
  }
  .btn-ghost {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    padding: 0.9rem 2rem;
    border: 1px solid var(--border);
    color: var(--neon);
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s;
  }
  .btn-ghost:hover {
    background: var(--neon-subtle);
    box-shadow: 0 0 12px var(--neon-glow);
  }

  /* Sections */
  .section {
    padding: 7rem 10vw;
    border-top: 1px solid var(--border);
  }
  .section-title {
    font-family: var(--font-pixel);
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    margin-bottom: 3.5rem;
    letter-spacing: 0.1em;
  }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .about-text { font-size: 1rem; line-height: 2; color: var(--text-muted); }
  .about-stats { display: flex; flex-direction: column; gap: 1.5rem; }
  .stat-item { display: flex; align-items: baseline; gap: 1rem; }
  .stat-num { font-family: var(--font-pixel); font-size: 1.8rem; }
  .stat-item > span:last-child {
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  /* Games */
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .game-card {
    background: var(--bg-card);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .game-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 24px var(--neon-glow);
  }
  .game-thumb {
    height: 140px;
    background: repeating-linear-gradient(
      45deg,
      var(--bg-alt) 0px, var(--bg-alt) 4px,
      var(--neon-subtle) 4px, var(--neon-subtle) 8px
    );
  }
  .game-year  { font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.1em; }
  .game-title { font-family: var(--font-pixel); font-size: 0.6rem; color: var(--neon); margin: 0.3rem 0; }
  .game-genre { font-size: 0.75rem; color: var(--text-muted); }
  .game-arrow {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    color: var(--neon);
    font-size: 1.1rem;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
  }
  .game-card:hover .game-arrow { opacity: 1; transform: translateX(4px); }

  /* Skills */
  .skills-list { display: flex; flex-direction: column; gap: 1.5rem; max-width: 640px; }
  .skill-row   { display: grid; grid-template-columns: 160px 1fr 48px; gap: 1rem; align-items: center; }
  .skill-label { font-family: var(--font-display); font-size: 0.65rem; letter-spacing: 0.1em; color: var(--text-muted); }
  .skill-bar-bg {
    height: 4px;
    background: rgba(255,255,255,0.07);
    overflow: hidden;
  }
  .skill-bar {
    height: 100%;
    width: 0%;
    background: var(--neon);
    box-shadow: 0 0 8px var(--neon);
    transition: width 1.2s cubic-bezier(0.22,1,0.36,1);
  }
  .skill-pct { font-family: var(--font-mono); font-size: 0.75rem; text-align: right; }

  /* Contact */
   .contact-lead {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 3rem;
    line-height: 1.8;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }
  .contact-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }
  .contact-info {
    padding-top: 0.5rem;
  }
  .contact-email {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--neon);
    text-decoration: none;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(0,255,0,0.3);
    padding-bottom: 0.3rem;
    transition: color 0.2s, box-shadow 0.2s;
    display: inline-block;
  }
  .contact-email:hover {
    color: #33ff33;
    text-shadow: 0 0 10px rgba(0,255,0,0.6);
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.12em;
  }
  .form-input {
    background: rgba(0,255,0,0.04);
    border: 1px solid rgba(0,255,0,0.25);
    color: var(--neon);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    caret-color: var(--neon);
  }
  .form-input::placeholder {
    color: rgba(0,255,0,0.2);
  }
  .form-input:focus {
    border-color: var(--neon);
    box-shadow: 0 0 12px rgba(0,255,0,0.2);
  }
  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }
  .contact-btn {
    align-self: flex-start;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    border: none;
    cursor: pointer;
    font-size: 0.7rem;
  }
  .btn-blink {
    animation: blink 1s step-end infinite;
    font-size: 0.8rem;
  }
  .btn-icon { font-size: 0.9rem; }
  .cf-status {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    min-height: 1.2rem;
    letter-spacing: 0.05em;
  }
  .cf-status.ok  { color: var(--neon); }
  .cf-status.err { color: #ff4444; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    gsap.from('.hero-title .line1, .hero-title .line2', {
      opacity: 0, y: 40, duration: 0.9,
      stagger: 0.2, ease: 'power3.out', delay: 0.4,
    });

    // ── Contact Form (EmailJS SDK 동적 로드) ─────────────────
    const SERVICE_ID  = 'service_q8ece0f';
    const TEMPLATE_ID = 'template_afg6d69';
    const PUBLIC_KEY  = 'srjHslGd-PYq7iY_5';

    const btn    = document.getElementById('cf-submit');
    const label  = document.getElementById('cf-label');
    const status = document.getElementById('cf-status');

    // EmailJS SDK를 동적으로 로드 후 초기화
    const ejsScript = document.createElement('script');
    ejsScript.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js';
    ejsScript.onload = () => {
      emailjs.init(PUBLIC_KEY);
      console.log('[EmailJS] ready');
    };
    document.head.appendChild(ejsScript);

    btn?.addEventListener('click', async () => {
      const name  = document.getElementById('cf-name').value.trim();
      const email = document.getElementById('cf-email').value.trim();
      const msg   = document.getElementById('cf-msg').value.trim();

      if (!name || !email || !msg) {
        status.textContent = '> ERROR: 모든 필드를 입력해주세요.';
        status.className = 'cf-status err';
        return;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        status.textContent = '> ERROR: 올바른 이메일 형식이 아닙니다.';
        status.className = 'cf-status err';
        return;
      }
      if (typeof emailjs === 'undefined') {
        status.textContent = '> ERROR: 잠시 후 다시 시도해주세요.';
        status.className = 'cf-status err';
        return;
      }

      btn.disabled = true;
      label.textContent = 'SENDING...';
      status.textContent = '';

      try {
        const result = await emailjs.send(SERVICE_ID, TEMPLATE_ID, {
          from_name : name,
          reply_to  : email,
          message   : msg,
        });

        console.log('[EmailJS] success', result);
        label.textContent = 'SEND MESSAGE';
        status.textContent = '> TRANSMISSION COMPLETE ✓ 메시지가 전송됐습니다!';
        status.className = 'cf-status ok';
        document.getElementById('cf-name').value  = '';
        document.getElementById('cf-email').value = '';
        document.getElementById('cf-msg').value   = '';

      } catch (err) {
        console.error('[EmailJS] error', err);
        label.textContent = 'SEND MESSAGE';
        status.textContent = '> ERROR: ' + (err?.text || err?.message || JSON.stringify(err));
        status.className = 'cf-status err';
      } finally {
        btn.disabled = false;
      }
    });

    document.getElementById('cf-msg')?.addEventListener('keydown', e => {
      if (e.ctrlKey && e.key === 'Enter') btn?.click();
    });
  });

</script>
---
import Layout from '../layouts/Layout.astro';
import HeroSelect from '../components/HeroSelect.astro';
import SideScroller from '../components/SideScroller.astro';
---

<Layout title="PLAYER_ONE — Game Developer Portfolio">

  <!-- ── HERO ───────────────────────────────────────────── -->
  <HeroSelect />
  <SideScroller />
 

  <!-- ── CONTACT ────────────────────────────────────────── -->
  <section id="contact" class="section">
    <h2 class="section-title gsap-fade-in"><span class="neon-text">04.</span> CONTACT</h2>
    <p class="contact-lead gsap-fade-in">새로운 모험을 함께할 팀원을 찾고 있습니다.</p>
    <a href="mailto:hello@playeron.dev" class="btn-primary gsap-fade-in" data-hover>
      ✉ SEND MESSAGE
    </a>
  </section>

</Layout>

<!-- ── Page-level styles ─────────────────────────────────── -->
<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 10vw;
    position: relative;
  }
  .hero-sub {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    letter-spacing: 0.1em;
  }
  .hero-title {
    font-family: var(--font-pixel);
    font-size: clamp(2rem, 7vw, 5.5rem);
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }
  .hero-title .line1 { display: block; color: var(--text); }
  .hero-title .line2 { display: block; }
  .hero-desc {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    margin-bottom: 3rem;
  }
  .hero-cta { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .blink-cursor {
    position: absolute;
    bottom: 2rem; left: 10vw;
    font-family: var(--font-pixel);
    font-size: 1.2rem;
    color: var(--neon);
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  /* Buttons */
  .btn-primary {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    padding: 0.9rem 2rem;
    background: var(--neon);
    color: var(--bg);
    text-decoration: none;
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
    transition: box-shadow 0.2s, background 0.2s;
  }
  .btn-primary:hover {
    background: #33ff33;
    box-shadow: 0 0 20px var(--neon-glow);
  }
  .btn-ghost {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    padding: 0.9rem 2rem;
    border: 1px solid var(--border);
    color: var(--neon);
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s;
  }
  .btn-ghost:hover {
    background: var(--neon-subtle);
    box-shadow: 0 0 12px var(--neon-glow);
  }

  /* Sections */
  .section {
    padding: 7rem 10vw;
    border-top: 1px solid var(--border);
  }
  .section-title {
    font-family: var(--font-pixel);
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    margin-bottom: 3.5rem;
    letter-spacing: 0.1em;
  }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .about-text { font-size: 1rem; line-height: 2; color: var(--text-muted); }
  .about-stats { display: flex; flex-direction: column; gap: 1.5rem; }
  .stat-item { display: flex; align-items: baseline; gap: 1rem; }
  .stat-num { font-family: var(--font-pixel); font-size: 1.8rem; }
  .stat-item > span:last-child {
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  /* Games */
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .game-card {
    background: var(--bg-card);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .game-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 24px var(--neon-glow);
  }
  .game-thumb {
    height: 140px;
    background: repeating-linear-gradient(
      45deg,
      var(--bg-alt) 0px, var(--bg-alt) 4px,
      var(--neon-subtle) 4px, var(--neon-subtle) 8px
    );
  }
  .game-year  { font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.1em; }
  .game-title { font-family: var(--font-pixel); font-size: 0.6rem; color: var(--neon); margin: 0.3rem 0; }
  .game-genre { font-size: 0.75rem; color: var(--text-muted); }
  .game-arrow {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    color: var(--neon);
    font-size: 1.1rem;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
  }
  .game-card:hover .game-arrow { opacity: 1; transform: translateX(4px); }

  /* Skills */
  .skills-list { display: flex; flex-direction: column; gap: 1.5rem; max-width: 640px; }
  .skill-row   { display: grid; grid-template-columns: 160px 1fr 48px; gap: 1rem; align-items: center; }
  .skill-label { font-family: var(--font-display); font-size: 0.65rem; letter-spacing: 0.1em; color: var(--text-muted); }
  .skill-bar-bg {
    height: 4px;
    background: rgba(255,255,255,0.07);
    overflow: hidden;
  }
  .skill-bar {
    height: 100%;
    width: 0%;
    background: var(--neon);
    box-shadow: 0 0 8px var(--neon);
    transition: width 1.2s cubic-bezier(0.22,1,0.36,1);
  }
  .skill-pct { font-family: var(--font-mono); font-size: 0.75rem; text-align: right; }

  /* Contact */
  .contact-lead {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .about-grid  { grid-template-columns: 1fr; }
    .skill-row   { grid-template-columns: 120px 1fr 40px; }
  }
</style>

<!-- ── Skill bar GSAP animation ──────────────────────────── -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Animate skill bars when section enters viewport
    document.querySelectorAll('.skill-bar').forEach(bar => {
      const pct = bar.dataset.pct + '%';
      ScrollTrigger.create({
        trigger: bar,
        start: 'top 85%',
        onEnter: () => gsap.to(bar, { width: pct, duration: 1.2, ease: 'power2.out' })
      });
    });

    // Hero title stagger
    gsap.from('.hero-title .line1, .hero-title .line2', {
      opacity: 0,
      y: 40,
      duration: 0.9,
      stagger: 0.2,
      ease: 'power3.out',
      delay: 0.4,
    });
  });
</script>